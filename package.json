{
  "name": "yoayudo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "YoAyudo WhatsApp Bot Engine MVP.",
  "scripts": {
    "dev": "node src/app/dev_doctor.js && node --watch src/app/server.js",
    "start": "node src/app/server.js",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "demo:bot-engine": "node scripts/demo_bot_engine_preflight.js",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "pug": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "pg-mem": "^3.0.4",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
