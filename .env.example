# Runtime environment.
# Use "development" locally.
NODE_ENV=development

# HTTP server port.
PORT=3000

# PostgreSQL connection string.
# Local Docker Compose should expose Postgres on host port 5433
# to avoid conflicts with other local projects using 5432.
DATABASE_URL=postgres://yoayudo:yoayudo@localhost:5433/yoayudo

# Public/base URL for this app.
# In local development this usually matches the Express server.
APP_BASE_URL=http://localhost:3000

# Token used by Meta to verify the WhatsApp webhook.
# This development value is safe for local testing only.
WHATSAPP_VERIFY_TOKEN=dev_verify_token

# Meta WhatsApp Cloud API access token.
# Leave empty when using the mock/dev simulator.
# Never commit real tokens in .env.example.
WHATSAPP_ACCESS_TOKEN=

# WhatsApp phone number ID.
# In local development this should match the seeded/demo phone number.
WHATSAPP_PHONE_NUMBER_ID=demo-phone-number-id

# AI provider used by the AI Gateway.
# Use "openai" when testing Probar bot with real AI.
# Use "mock" only for deterministic local tests without external AI calls.
AI_PROVIDER=mock

# Required when AI_PROVIDER=openai. Never commit a real key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1

# AWS region used when AI_PROVIDER=bedrock.
AWS_REGION=us-east-1

# Bedrock model ID used when AI_PROVIDER=bedrock.
# Leave empty while using AI_PROVIDER=mock.
BEDROCK_MODEL_ID=

# Application log level.
# Common values: debug, info, warn, error.
LOG_LEVEL=info

# Memory store used for normalized memory/knowledge documents.
# Use "local" for development. Use "s3" for AWS.
MEMORY_STORE_PROVIDER=local
MEMORY_LOCAL_DIR=.storage/memory
MEMORY_S3_BUCKET=
MEMORY_S3_PREFIX=yoayudo/memory

# Knowledge Center document uploads.
# Credentials are read by the AWS SDK from the standard env vars:
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, and optional AWS_SESSION_TOKEN.
KNOWLEDGE_S3_BUCKET=
KNOWLEDGE_S3_PREFIX=yoayudo/knowledge
KNOWLEDGE_UPLOAD_MAX_BYTES=10485760

# Embeddings.
# Use "mock" locally. Future/prod can use "bedrock".
EMBEDDING_PROVIDER=mock
BEDROCK_EMBEDDING_MODEL_ID=

# Vector index abstraction.
# Use "mock" until a real vector index or Bedrock Knowledge Base is configured.
VECTOR_INDEX_PROVIDER=mock
VECTOR_INDEX_NAME=yoayudo-dev

# Agent router and memory ingestion flags.
AGENT_ROUTER_ENABLED=true
MEMORY_INGESTION_ENABLED=true

# Internal conversation/debug inspector.
INSPECTOR_ENABLED=true

# Optional internal token for production/staging.
# In development it can stay empty.
INSPECTOR_INTERNAL_TOKEN=
