extends layout

block content
  section.page-header
    h1 Negocios
    p Ordena ventas, compras y el cierre del día de tus negocios — por WhatsApp

  if !businesses || businesses.length === 0
    .empty Ejecuta el seed de desarrollo para crear YoAyudo.
  else
    .table-wrap
      table
        thead
          tr
            th Negocio
            th Estado
            th Cuentas
            th Bots
            th
        tbody
          each business in businesses
            tr
              td= business.name
              td
                span.status= business.status
              td= business.account_count
              td= business.bot_count
              td
                a.button(href=`/dashboard/business/${business.id}`) Abrir

  if hidden_business_count
    p.meta
      = `${hidden_business_count} negocio${hidden_business_count === 1 ? "" : "s"} pausado${hidden_business_count === 1 ? "" : "s"} o archivado${hidden_business_count === 1 ? "" : "s"} no se muestra${hidden_business_count === 1 ? "" : "n"} aquí. `
      a(href="/admin/businesses") Gestionarlos en Admin
