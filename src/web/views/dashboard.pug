extends layout

block content
  section.page-header
    h1 Negocios
    p Motor de bots y agentes de WhatsApp

  if !businesses || businesses.length === 0
    .empty Ejecuta el seed de desarrollo para crear YoAyudo.
  else
    .table-wrap
      table
        thead
          tr
            th Negocio
            th Estado
            th Cuentas
            th Bots
            th
        tbody
          each business in businesses
            tr
              td= business.name
              td
                span.status= business.status
              td= business.account_count
              td= business.bot_count
              td
                a.button(href=`/dashboard/business/${business.id}`) Abrir
