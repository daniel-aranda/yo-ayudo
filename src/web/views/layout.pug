//- Shared breadcrumb. Pass items as [{ label, href? }]; the last item (or any
//- without href) renders as the current page. Available to every view via extends.
mixin breadcrumb(items)
  if items && items.length
    nav.breadcrumb(aria-label="Migas de pan")
      each item, index in items
        if index > 0
          span.breadcrumb-sep ›
        if item.href
          a(href=item.href)= item.label
        else
          span.breadcrumb-current= item.label

doctype html
html(lang="es")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title YoAyudo
    link(rel="stylesheet", href="/public/css/dashboard.css")
  body
    - const nav_active = typeof active_nav !== "undefined" ? active_nav : "";
    header.topbar
      a.brand(href="/dashboard") YoAyudo
      nav.nav
        a(href="/dashboard", class=(nav_active === "dashboard" ? "is-active" : ""), aria-current=(nav_active === "dashboard" ? "page" : false)) Dashboard
        a(href="/inspector", class=(nav_active === "inspector" ? "is-active" : ""), aria-current=(nav_active === "inspector" ? "page" : false)) Inspector
        a(href="/review", class=(nav_active === "review" ? "is-active" : ""), aria-current=(nav_active === "review" ? "page" : false)) Review
        a(href="/admin/integrations", class=(nav_active === "admin" ? "is-active" : ""), aria-current=(nav_active === "admin" ? "page" : false)) Admin
    main.container
      block content
