extends ../layout

block content
  -
    const when = (value) => {
      try { return value ? new Date(value).toLocaleString("es-MX") : "—"; } catch (error) { return "—"; }
    };
    const days = Math.round((since_hours || 168) / 24);
    const current_hours = since_hours || 168;
    const periods = [
      { hours: 24, label: "24 h" },
      { hours: 168, label: "7 días" },
      { hours: 720, label: "30 días" },
    ];
    const bots_query = (hours) => {
      const params = new URLSearchParams();
      params.set("since_hours", String(hours));
      if (filters.q) params.set("q", filters.q);
      if (filters.type !== "system") params.set("type", filters.type);
      if (filters.include_archived) params.set("archived", "1");
      return `/admin/bots?${params.toString()}`;
    };
    const type_label = (value) => (value === "system" ? "Sistema" : value === "custom" ? "Personalizado" : value);
    const filters_active = Boolean(filters.q) || filters.type !== "system" || filters.include_archived;
    const toggle_archived_href = (() => {
      const params = new URLSearchParams();
      params.set("since_hours", String(current_hours));
      if (filters.q) params.set("q", filters.q);
      if (filters.type !== "system") params.set("type", filters.type);
      if (!filters.include_archived) params.set("archived", "1");
      return `/admin/bots?${params.toString()}`;
    })();
    const svg_open = '<svg class="ui-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">';
    const action_icons = {
      play: `${svg_open}<circle cx="12" cy="12" r="9"/><path d="M10 8.5l5.5 3.5L10 15.5z" fill="currentColor" stroke="none"/></svg>`,
      pause: `${svg_open}<circle cx="12" cy="12" r="9"/><path d="M10 9v6M14 9v6"/></svg>`,
      archive: `${svg_open}<rect x="3.5" y="4.5" width="17" height="4.5" rx="1"/><path d="M5.5 9v9a1.5 1.5 0 0 0 1.5 1.5h10a1.5 1.5 0 0 0 1.5-1.5V9"/><path d="M10 12.5h4"/></svg>`,
      copy: `${svg_open}<rect x="9" y="9" width="11" height="11" rx="1.5"/><path d="M5.5 15H5a1.5 1.5 0 0 1-1.5-1.5v-9A1.5 1.5 0 0 1 5 3h9A1.5 1.5 0 0 1 15.5 4.5V5"/></svg>`,
    };

  .admin-subnav
    a(href="/admin/integrations") Integraciones
    a(href="/admin/interactions") Interacciones
    a.is-active(href="/admin/bots") Bots
    a(href="/admin/businesses") Negocios
    a(href="/admin/conversations") Conversaciones
    a(href="/admin/tasks") Tareas
    a(href="/admin/guardrails") Guardrails

  section.page-header
    .page-header-row
      div
        h1 Bots
        p= `Bots de la plataforma y su uso · últimos ${days} días`
      button#open_create_bot(type="button") Crear bot

  .period-filter
    span.period-filter-label Periodo
    each period in periods
      a(href=bots_query(period.hours), class=(current_hours === period.hours ? "is-active" : ""))= period.label

  //- Default: catálogo de bots de sistema vivos. Una sola fila, sin botón:
  //- filtra solo con escribir o cambiar el tipo. Archivados = link de abajo.
  section.panel.bots-toolbar
    form#bots_filter_form.inline-form(method="get", action="/admin/bots")
      input(type="hidden", name="since_hours", value=current_hours)
      if filters.include_archived
        input(type="hidden", name="archived", value="1")
      input(type="search", name="q", value=filters.q, placeholder="Buscar por nombre, negocio o cuenta", aria-label="Buscar bot")
      select(name="type", aria-label="Tipo de bot")
        option(value="system", selected=filters.type === "system") Sistema
        option(value="custom", selected=filters.type === "custom") Personalizados
        option(value="all", selected=filters.type === "all") Todos

  .metrics
    article.metric
      span.label Bots
      strong= totals.bots
    article.metric
      span.label Activos
      strong= totals.active
    article.metric
      span.label Mensajes
      strong= totals.messages
    article.metric
      span.label Errores
      strong= totals.errors

  section.panel
    h2 Bots / agentes
    if bots && bots.length
      .table-wrap
        table.activity-table
          thead
            tr
              th Bot
              //- Los bots de sistema son de plataforma (clonables a cualquier
              //- cuenta); en su vista la columna Negocio/cuenta no aplica.
              if filters.type !== "system"
                th Negocio / cuenta
              th Tipo
              th Estado
              th Mensajes
              th Conversaciones
              th Errores
              th Última actividad
              th Acciones
          tbody
            each bot in bots
              tr
                td
                  a(href=`/inspector/bots/${bot.id}`)= bot.name
                  if bot.description
                    div.meta= bot.description
                if filters.type !== "system"
                  td.meta= bot.bot_type === "system" ? "Plataforma" : `${bot.organization_name} · ${bot.account_name}`
                td
                  span(class=`bot-type-chip is-${bot.bot_type}`)= type_label(bot.bot_type)
                td
                  span(class=`status-pill ${bot.status === "active" ? "status-executed" : bot.status === "draft" ? "status-pending_provider" : "status-blocked"}`)= bot.status
                td= bot.messages
                td= bot.conversations
                td
                  if bot.errors
                    span.count-error= bot.errors
                  else
                    = 0
                td.meta= when(bot.last_at)
                td
                  .bot-actions
                    if bot.status !== "active"
                      form(method="post", action=`/admin/bots/${bot.id}/status`)
                        input(type="hidden", name="status", value="active")
                        button.icon-button(type="submit", title="Activar", aria-label=`Activar ${bot.name}`)!= action_icons.play
                    if bot.status === "active"
                      form(method="post", action=`/admin/bots/${bot.id}/status`)
                        input(type="hidden", name="status", value="draft")
                        button.icon-button(type="submit", title="Pausar (pasa a borrador)", aria-label=`Pausar ${bot.name}`)!= action_icons.pause
                    if bot.status !== "archived"
                      form(method="post", action=`/admin/bots/${bot.id}/status`, data-confirm=`¿Archivar "${bot.name}"? Dejará de operar y se ocultará de la vista (puedes restaurarlo desde "Ver archivados").`)
                        input(type="hidden", name="status", value="archived")
                        button.icon-button(type="submit", title="Archivar", aria-label=`Archivar ${bot.name}`)!= action_icons.archive
                    form(method="post", action=`/admin/bots/${bot.id}/clone`)
                      button.icon-button(type="submit", title="Clonar (copia custom en borrador)", aria-label=`Clonar ${bot.name}`)!= action_icons.copy
    else if filters_active
      .empty Sin bots que coincidan con los filtros.
    else
      .empty Sin bots registrados.

  //- Archivados fuera de la vista por default; un link discreto los trae.
  p.archived-link
    if filters.include_archived
      a(href=toggle_archived_href) Ocultar archivados
    else
      a(href=toggle_archived_href)= archived_count ? `Ver archivados (${archived_count})` : "Ver archivados"

  //- Crear bot de sistema: nombre + descripción → draft, se configura en el editor.
  #create_bot_popup.popup-overlay(data-popup-overlay, data-popup-overlay-close="true", data-create-bot-popup)
    .popup.popup--md.popup--default
      .popup__header
        .popup__header-text
          h3.popup__title Crear bot de sistema
          .popup__subtitle Un bot de plataforma, clonable a cualquier cuenta. Lo configuras en el editor.
        button.popup__close(type="button", data-popup-close, aria-label="Cerrar") ✕
      .popup__body
        form.popup-form.channel-add-form(method="post", action="/admin/bots")
          .popup-field
            label(for="new_bot_name") Nombre
            input#new_bot_name(type="text", name="name", placeholder="p. ej. Bot Reservas", required)
          .popup-field
            label(for="new_bot_description") Descripción
            input#new_bot_description(type="text", name="description", placeholder="Qué hace este bot")
            p.field-hint Se crea en borrador; defines prompt, acciones y knowledge en el editor.
          div.form-actions.form-actions--full
            button(type="submit") Crear bot

  script
    include ../../public/js/core/Popup.js

  script.
    (() => {
      const createBotPopup = window.Popup ? new window.Popup({ overlay_selector: "[data-create-bot-popup]" }) : null;
      createBotPopup?.iniciar();
      document.getElementById("open_create_bot")?.addEventListener("click", () => createBotPopup?.open());
    })();

  script.
    (() => {
      // Confirmación para acciones destructivas (archivar).
      document.addEventListener("submit", (event) => {
        const form = event.target.closest("form[data-confirm]");
        if (form && !window.confirm(form.dataset.confirm)) event.preventDefault();
      });

      const form = document.getElementById("bots_filter_form");
      if (!form) return;
      form.querySelector('select[name="type"]')?.addEventListener("change", () => form.submit());
      const search = form.querySelector('input[name="q"]');
      let timer;
      search?.addEventListener("input", () => {
        clearTimeout(timer);
        timer = setTimeout(() => form.submit(), 450);
      });
    })();
