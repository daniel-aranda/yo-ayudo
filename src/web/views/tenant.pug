extends layout

block content
  if !tenant
    .empty Tenant no encontrado.
  else
    section.page-header
      h1= tenant.name
      p= tenant.slug

    if !branches || branches.length === 0
      .empty Sin sucursales configuradas.
    else
      .grid
        each branch in branches
          article.card
            h2= branch.name
            p= branch.address || "Sin dirección"
            p Última operación: #{branch.last_operation_date || "sin datos"}
            a.button(href=`/dashboard/tenants/${tenant.id}/branches/${branch.id}`) Ver sucursal
