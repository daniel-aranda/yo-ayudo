extends ../layout

block content
  - const scoped_account = (typeof account !== "undefined" && account) ? account : null;
  section.page-header
    if scoped_account
      p.page-eyebrow= `Cuenta · Negocio: ${scoped_account.organization_name}`
      h1= scoped_account.name
      p Inspector de bots y agentes de esta cuenta
    else
      h1= business ? business.name : "YoAyudo"
      p Inspector de bots y agentes

  if scoped_account
    .scope-banner
      span Mostrando solo los bots de #{scoped_account.name}.
      a(href="/inspector") Ver todos los bots

  section.panel
    h2 Bots / agentes
    if bots && bots.length
      table
        thead
          tr
            th Nombre
            th Tipo
            th Estado
            th Cuenta
            th
        tbody
          each bot in bots
            tr
              td
                a(href=`/inspector/bots/${bot.id}`)= bot.name
                if bot.description
                  div.meta= bot.description
              td= bot.bot_type || bot.channel
              td
                span.status= bot.status
              td= bot.account_name || "sin cuenta"
              td
                a.button(href=`/inspector/bots/${bot.id}`) Editar
    else
      div.empty Sin bots configurados.
