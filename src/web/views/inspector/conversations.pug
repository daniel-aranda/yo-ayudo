extends ../layout

block content
  -
    const account_url = bot && bot.account_id ? `/dashboard/accounts/${bot.account_id}` : "/dashboard";
    const bc = [{ label: "Dashboard", href: "/dashboard" }];
    if (bot) {
      bc.push({ label: bot.account_name || "Cuenta", href: account_url });
      bc.push({ label: bot.name || "Bot", href: `/inspector/bots/${bot.id}` });
    }
    bc.push({ label: "Conversaciones" });
  +breadcrumb(bc)
  section.page-header
    h1 Conversaciones
    if bot
      p= `Senders y conversaciones de ${bot.name}.`
    else
      p Senders y conversaciones del bot.

  section.panel
    -
      const pending_review_total = conversations.reduce((sum, c) => sum + Number(c.pending_review_count || 0), 0);
      const multi_interaction_total = conversations.filter((c) => Array.isArray(c.interactions) && c.interactions.length > 1).length;
    if conversations.length
      .conversation-rollup
        span.conversation-rollup__item
          strong= conversations.length
          |  conversaciones
        span.conversation-rollup__item(class=pending_review_total ? "is-warning" : "")
          strong= pending_review_total
          |  en revisión
        span.conversation-rollup__item
          strong= multi_interaction_total
          |  multi-interacción
    +conversation_list(conversations, { account_id: bot && bot.account_id, show_bot: false })
