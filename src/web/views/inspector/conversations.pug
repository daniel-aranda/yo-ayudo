extends ../layout

block content
  -
    const account_url = bot && bot.account_id ? `/dashboard/accounts/${bot.account_id}` : "/dashboard";
    const bc = [{ label: "Dashboard", href: "/dashboard" }];
    if (bot) {
      bc.push({ label: bot.account_name || "Cuenta", href: account_url });
      bc.push({ label: bot.name || "Bot", href: `/inspector/bots/${bot.id}` });
    }
    bc.push({ label: "Conversaciones" });
  +breadcrumb(bc)
  section.page-header
    h1 Conversaciones
    if bot
      p= `Senders y conversaciones de ${bot.name}.`
    else
      p Senders y conversaciones del bot.

  section.panel
    form(method="get").filters
      label(for="search") Buscar
      input#search(name="search", value=search || "")
      button(type="submit") Filtrar

  section.panel
    if conversations.length
      table.conversations-table
        thead
          tr
            th.conv-sender Contacto
            th Último mensaje
            th Interacciones
            th Mensajes
            th Revisión
            th Última actividad
            th Estado
        tbody
          each conversation in conversations
            tr
              td.conv-sender
                a(href=(bot && bot.account_id ? `/inspector/accounts/${bot.account_id}/conversations/${conversation.id}` : `/inspector/conversations/${conversation.id}`))= conversation.display_name || phone(conversation.whatsapp_phone)
                if conversation.display_name
                  div.meta= phone(conversation.whatsapp_phone)
              td= conversation.last_message || "-"
              td
                if conversation.interactions && conversation.interactions.length
                  .conv-tags
                    each interaction in conversation.interactions
                      span.conv-tag= interaction.label
                else
                  | -
              td= conversation.messages_count
              td= conversation.pending_review_count
              td= conversation.last_activity_label || "-"
              td
                span.status= conversation.summary ? conversation.summary.status_label : conversation.status
    else
      div.empty Sin conversaciones.
