extends ../layout

block content
  -
    const metadata = source.metadata_json || {};
    const file = metadata.file || null;
    const knowledge_type_label = (type) => {
      if (type === "document") return "Documento";
      if (type === "url") return "URL";
      return "Texto";
    };

  section.page-header.builder-header
    div
      h1= source.name
      p Knowledge source
    div.builder-actions
      a.button.secondary-button(href=back_url) Volver

  form(method="post", action=form_action)

    section.panel
      h2 Editar knowledge
      div.form-grid
        div
          label Nombre
          input(type="text", name="name", value=source.name)
        div
          label Tipo de knowledge
          input(type="text", value=knowledge_type_label(source.source_type), readonly)
        div
          label Scope
          input(type="text", value=source.scope, readonly)
        div
          label Estado
          select(name="status")
            each option in ["ready", "active", "draft", "archived"]
              option(value=option, selected=source.status === option)= option
        div
          label Summary status
          select(name="summary_status")
            each option in ["ready", "pending_ingestion", "draft", "failed"]
              option(value=option, selected=(source.summary_status || "ready") === option)= option
        if source.origin
          div
            label Origen
            input(type="text", value=source.origin, readonly)

      label Descripción
      textarea(name="description", rows="4")= source.description || ""

      div.markdown-editor
        div.section-title
          label(for="knowledge_source_body") Knowledge
          div.segmented-control(role="tablist", aria-label="Vista de knowledge")
            button.secondary-button#show_knowledge_preview(type="button", aria-pressed="true") Preview
            button.secondary-button#show_knowledge_source(type="button", aria-pressed="false") Source
        div.markdown-preview#knowledge_preview
        textarea#knowledge_source_body.markdown-source(name="summary", rows="22", hidden)= source.summary || ""

      if source.source_type === "url" || metadata.url
        label URL
        input(type="url", name="url", value=metadata.url || "", placeholder="https://...")

      div.form-actions
        button(type="submit") Guardar cambios
        a.button.secondary-button(href=back_url) Cancelar

  if metadata.url
    section.panel
      h2 URL
      a(href=metadata.url, target="_blank", rel="noreferrer")= metadata.url

  if file
    section.panel
      h2 Archivo S3
      dl.compact
        div
          dt Archivo
          dd= file.original_filename || "sin nombre"
        div
          dt Bucket
          dd= file.bucket || "sin bucket"
        div
          dt Key
          dd= file.key || "sin key"
        div
          dt Tipo
          dd= file.mime_type || "sin mime type"
        div
          dt Tamaño
          dd= file.size_bytes ? String(file.size_bytes) + " bytes" : "sin tamaño"

  section.panel
    h2 Metadata
    pre= json(metadata)

  script.
    (() => {
      const textarea = document.getElementById("knowledge_source_body");
      const preview = document.getElementById("knowledge_preview");
      const previewButton = document.getElementById("show_knowledge_preview");
      const sourceButton = document.getElementById("show_knowledge_source");

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function inlineMarkdown(value) {
        return escapeHtml(value)
          .replace(/`([^`]+)`/g, "<code>$1</code>")
          .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
      }

      function renderMarkdown(markdown) {
        const lines = String(markdown || "").split(/\r?\n/);
        const html = [];
        let paragraph = [];
        let list = [];

        function flushParagraph() {
          if (!paragraph.length) return;
          html.push(`<p>${inlineMarkdown(paragraph.join(" "))}</p>`);
          paragraph = [];
        }

        function flushList() {
          if (!list.length) return;
          html.push(`<ul>${list.map((item) => `<li>${inlineMarkdown(item)}</li>`).join("")}</ul>`);
          list = [];
        }

        for (const line of lines) {
          const trimmed = line.trim();

          if (!trimmed) {
            flushParagraph();
            flushList();
            continue;
          }

          const heading = trimmed.match(/^(#+)\s+(.+)$/);
          if (heading) {
            flushParagraph();
            flushList();
            const level = Math.min(heading[1].length, 4);
            html.push(`<h${level}>${inlineMarkdown(heading[2])}</h${level}>`);
            continue;
          }

          const bullet = trimmed.match(/^[-*]\s+(.+)$/);
          if (bullet) {
            flushParagraph();
            list.push(bullet[1]);
            continue;
          }

          flushList();
          paragraph.push(trimmed);
        }

        flushParagraph();
        flushList();
        return html.join("");
      }

      function updatePreview() {
        if (!preview || !textarea) return;
        preview.innerHTML = renderMarkdown(textarea.value) || '<p class="meta">Sin knowledge.</p>';
      }

      function setMode(mode) {
        const isPreview = mode === "preview";
        preview.hidden = !isPreview;
        textarea.hidden = isPreview;
        previewButton.setAttribute("aria-pressed", String(isPreview));
        sourceButton.setAttribute("aria-pressed", String(!isPreview));
      }

      previewButton?.addEventListener("click", () => {
        updatePreview();
        setMode("preview");
      });

      sourceButton?.addEventListener("click", () => setMode("source"));
      textarea?.addEventListener("input", updatePreview);

      updatePreview();
      setMode("preview");
    })();
