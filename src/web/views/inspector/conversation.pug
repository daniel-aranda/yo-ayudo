extends ../layout

block content
  -
    const contact_name = conversation ? (conversation.display_name || conversation.whatsapp_phone || "Contacto") : "Contacto";
    const resolved_account_id = conversation ? (conversation.resolved_account_id || conversation.account_id) : null;
    const dashboard_url = resolved_account_id ? `/dashboard/accounts/${resolved_account_id}` : "/dashboard";
    const conversations_url = conversation && conversation.bot_id ? `/inspector/bots/${conversation.bot_id}/conversations` : "/inspector";
    const status_value = conversation ? (conversation.status || "open") : "open";
    const status_label = status_value === "closed" ? "Cerrada" : status_value === "open" ? "Abierta" : status_value;
    const bot_phone = conversation ? (conversation.bot_display_phone_number || conversation.bot_phone_number_id || "") : "";
    const value = value_summary || {};
    const task_count = Array.isArray(tasks) ? tasks.length : 0;
    const open_task_count = Array.isArray(tasks) ? tasks.filter((task) => task.status !== "hecha").length : 0;
    const sales_count = Number(value.sales?.count || 0);
    const purchases_count = Number(value.purchases?.count || 0);
    const inventory_count = Number(value.inventory?.count || 0);
    const notes_count = Array.isArray(value.notes) ? value.notes.length : 0;
    const crm_clients = Array.isArray(value.crm) ? value.crm : [];
    const crm_count = crm_clients.length;
    const client_key_type_labels = { curp: "CURP", phone: "Teléfono", instagram: "Instagram", email: "Email", internal: "ID interno" };
    const purchase_items = Array.isArray(value.purchases?.items) ? value.purchases.items : [];
    const latest_purchase = purchase_items[0] || null;
    const has_opening_cash = value.opening_cash !== undefined && value.opening_cash !== null;
    const has_closing_cash = value.closing_cash !== undefined && value.closing_cash !== null;
    const has_value_summary = Boolean(value.has_value || task_count);
    const copy_svg = '<svg class="ui-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
    const check_svg = '<svg class="ui-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';
    const calendar_svg = '<svg class="ui-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M16 2.5v4M8 2.5v4M3 9.5h18"/></svg>';
    const clock_svg = '<svg class="ui-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 1.8"/></svg>';
    const phone_svg = '<svg class="ui-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>';
    // datetime() = "fecha, hora"; separamos para mostrar fecha (icono calendario) y
    // hora (icono reloj) sin la coma de enmedio. Sin helper nuevo.
    const last_dt = overview && overview.last_at ? datetime(overview.last_at) : "";
    const last_time = last_dt.includes(", ") ? last_dt.split(", ").slice(1).join(", ") : "";

  //- Botón de copiar como ícono (clipboard → check al copiar). El feedback es por
  //- clase .is-copied (no se toca el innerHTML, para no borrar el SVG).
  mixin copy_icon(value, label)
    button.copy-btn(type="button", data-copy=value, aria-label=label, title="Copiar")
      span.copy-ico.copy-ico-default!= copy_svg
      span.copy-ico.copy-ico-done!= check_svg

  if !conversation
    section.page-header
      h1 Conversación
    .empty No se encontró la conversación.
  else
    +breadcrumb([{ label: "Dashboard", href: "/dashboard" }, { label: conversation.account_name || "Negocio", href: dashboard_url }, { label: conversation.bot_name || "Bot", href: conversation.bot_id ? `/inspector/bots/${conversation.bot_id}` : conversations_url }, { label: "Conversaciones", href: conversations_url }, { label: contact_name }])

    section.page-header.conversation-header
      .conversation-header-main
        h1= `Conversación con ${contact_name}`
        p.meta= `${conversation.bot_name || "sin bot"} · ${conversation.whatsapp_phone || "sin teléfono"}`
      .conversation-header-aside
        span.status-badge(class=`is-${status_value}`)= status_label
        a.button.button-ghost(href=dashboard_url) ← Volver al dashboard

    .inspector-layout.conversation-view
      section.inspector-main
        if view_turns && view_turns.length
          //- Franja genérica de conversación: aplica a CUALQUIER bot. Las métricas
          //- de dominio (venta acumulada, caja, etc.) son capability-driven y viven
          //- en "Estado del día" (sidebar), no aquí.
          .conv-summary
            .conv-summary-item
              span.conv-summary-key Turnos
              span.conv-summary-val= overview.turns_count
            .conv-summary-item
              span.conv-summary-key Última acción
              span.conv-summary-val= overview.last_action || "Sin acción"
            .conv-summary-item
              span.conv-summary-key Errores
              span.conv-summary-val(class=(overview.errors_count ? "is-error" : ""))= overview.errors_count
            .conv-summary-item
              span.conv-summary-key Última actualización
              if overview.last_at
                span.conv-summary-val.dt-val
                  span.dt-chip
                    span.dt-ico!= calendar_svg
                    span= date(overview.last_at)
                  if last_time
                    span.dt-chip
                      span.dt-ico!= clock_svg
                      span= last_time
              else
                span.conv-summary-val No disponible
          .conversation-thread
            each turn in view_turns
              article.turn(class=`turn--${turn.status_tone}`)
                span.turn-status-bar(aria-hidden="true")
                .turn-body
                  if turn.user
                    .turn-msg.turn-msg--user
                      .msg-head
                        span.msg-author Usuario
                        span.msg-time= datetime(turn.user.at)
                      p.msg-text= turn.user.text || "(sin texto)"
                  if turn.understanding
                    //- Labels de acción derivados del mensaje del usuario (flecha
                    //- conectora). El detalle (intención + confianza) vive en un
                    //- popover al hacer click, para no robar atención al mensaje.
                    .turn-actions
                      span.turn-actions-arrow(aria-hidden="true")
                        svg(width="18", height="18", viewBox="0 0 20 20", fill="none", stroke="currentColor", stroke-width="1.6", stroke-linecap="round", stroke-linejoin="round")
                          path(d="M6 3v6.5a2.5 2.5 0 0 0 2.5 2.5H15")
                          path(d="M12.5 9.5 15 12l-2.5 2.5")
                      .turn-actions-list
                        if turn.understanding.has_action
                          each action in turn.understanding.actions
                            if action.task
                              span.turn-action-combo
                                button.turn-action-chip(type="button", class=`is-${action.tone}`, aria-haspopup="dialog", aria-expanded="false")= action.label
                                button.turn-task-button(type="button", data-open-task=action.task.id, aria-label=`Abrir tarea derivada: ${action.task.titulo}`) Ver tarea
                            else if action.client
                              span.turn-action-combo
                                button.turn-action-chip(type="button", class=`is-${action.tone}`, aria-haspopup="dialog", aria-expanded="false")= action.label
                                button.turn-task-button(type="button", data-open-client=action.client.id, aria-label=`Abrir prospecto: ${action.client.display_name}`) Ver prospecto
                            else
                              button.turn-action-chip(type="button", class=`is-${action.tone}`, aria-haspopup="dialog", aria-expanded="false")= action.label
                        else
                          span.turn-action-none Sin acción ejecutada
                      if turn.understanding.intent_human || turn.understanding.confidence_pct != null
                        .turn-detail(role="dialog", aria-label="Interpretación del agente", hidden)
                          if turn.understanding.intent_human
                            .turn-detail-row
                              span.turn-detail-key Intención
                              span.turn-detail-val= turn.understanding.intent_human
                          if turn.understanding.confidence_pct != null
                            .turn-detail-row
                              span.turn-detail-key Confianza
                              span.turn-detail-val(class=`is-${turn.understanding.confidence_tone}`)= `${turn.understanding.confidence_pct}%`
                  if turn.responses && turn.responses.length
                    each response in turn.responses
                      .turn-msg.turn-msg--agent
                        .msg-head
                          span.msg-author Agente
                          span.msg-time= datetime(response.at)
                        p.msg-text= response.text || "(sin texto)"
                  else if turn.user
                    p.turn-pending Sin respuesta del agente todavía.
                  if turn.trace_id
                    .turn-foot
                      a.trace-link(href=`/inspector/messages/${turn.trace_id}`) Ver trace completo →
        else
          .empty Sin mensajes en esta conversación.

      aside.inspector-sidebar
        section.inspector-panel
          h2 Contacto y canal
          dl.compact
            div
              dt Nombre
              dd= contact_name
            div
              dt Teléfono
              dd.with-copy
                span.field-value
                  span.field-ico!= phone_svg
                  span= conversation.whatsapp_phone ? phone(conversation.whatsapp_phone) : "-"
                if conversation.whatsapp_phone
                  +copy_icon(conversation.whatsapp_phone, "Copiar teléfono")
            div
              dt Número del bot
              dd.with-copy
                span.field-value
                  span.field-ico!= phone_svg
                  span= bot_phone ? phone(bot_phone) : "-"
                if bot_phone
                  +copy_icon(bot_phone, "Copiar número del bot")
            div
              dt Estado
              dd
                span.status-badge(class=`is-${status_value}`)= status_label

        if has_value_summary
          section.inspector-panel.conv-value-panel
            h2 Valor capturado
            ul.conv-value-list
              if crm_count
                li.conv-value-row.conv-value-row--stack
                  span.conv-value-label= crm_count === 1 ? "Prospecto / cliente" : "Prospectos / clientes"
                  //- Cada prospecto/cliente abre su detalle en popup (igual que Tareas).
                  ul.conv-tasks
                    each client in crm_clients
                      li
                        button.conv-task-row(type="button", data-open-client=client.id)
                          .conv-task-line
                            span.conv-task-title= client.display_name || client.client_key
                            span(class=`task-pill is-${client.kind === "cliente" ? "hecha" : "pendiente"}`)= `${client.kind === "cliente" ? "Cliente" : "Prospecto"} · ${client_key_type_labels[client.client_key_type] || client.client_key_type}`
                          span.conv-task-cta Ver prospecto →
              if task_count
                li.conv-value-row
                  span.conv-value-label Tareas
                  .conv-value-main
                    strong= open_task_count ? `${open_task_count} abiertas` : `${task_count} totales`
                    if open_task_count && open_task_count !== task_count
                      small= `${task_count} totales`
              if sales_count
                li.conv-value-row
                  span.conv-value-label Ventas
                  .conv-value-main
                    strong= value.sales.latest_amount != null ? money(value.sales.latest_amount) : `${sales_count} registros`
                    small= sales_count === 1 ? "1 actualización" : `${sales_count} actualizaciones`
              if has_opening_cash
                li.conv-value-row
                  span.conv-value-label Caja inicial
                  .conv-value-main
                    strong= money(value.opening_cash)
              if has_closing_cash
                li.conv-value-row
                  span.conv-value-label Caja final
                  .conv-value-main
                    strong= money(value.closing_cash)
              if purchases_count
                li.conv-value-row
                  span.conv-value-label Compras
                  .conv-value-main
                    strong= money(value.purchases.total)
                    small= purchases_count === 1 ? "1 compra" : `${purchases_count} compras`
              if latest_purchase
                li.conv-value-row.conv-value-row--stack
                  span.conv-value-label Última compra
                  p= [latest_purchase.item_name, latest_purchase.quantity, latest_purchase.unit].filter(Boolean).join(" ")
              if inventory_count
                li.conv-value-row
                  span.conv-value-label Inventario
                  .conv-value-main
                    strong= inventory_count === 1 ? "1 conteo" : `${inventory_count} conteos`
              if notes_count
                li.conv-value-row
                  span.conv-value-label Notas
                  .conv-value-main
                    strong= notes_count === 1 ? "1 nota" : `${notes_count} notas`
              if value.latest_summary
                li.conv-value-row.conv-value-row--stack
                  span.conv-value-label Resumen
                  p= value.latest_summary

        if tasks && tasks.length
          section.inspector-panel
            h2 Tareas
            //- Slim: solo título + estado; el detalle (quién atendió/qué pasó)
            //- vive en el popup que abre al hacer click.
            ul.conv-tasks
              each task in tasks
                li
                  button.conv-task-row(type="button", data-open-task=task.id)
                    .conv-task-line
                      span.conv-task-title= task.titulo
                      span(class=`task-pill is-${task.status}`)= task.status_label
                    span.conv-task-cta Ver tarea →

  //- Detalle de la tarea (estado + historial) en popup, sin salir de la conversación.
  #task_detail_popup.popup-overlay(data-popup-overlay, data-popup-overlay-close="true", data-task-popup)
    .popup.popup--lg.popup--default
      .popup__header
        .popup__header-text
          h3.popup__title Tarea
        button.popup__close(type="button", data-popup-close, aria-label="Cerrar") ✕
      .popup__body.popup__body--taskframe
        iframe#task_detail_frame(title="Detalle de la tarea")

  //- Detalle del prospecto/cliente en popup, mismo patrón que el de tarea.
  #crm_detail_popup.popup-overlay(data-popup-overlay, data-popup-overlay-close="true", data-client-popup)
    .popup.popup--lg.popup--default
      .popup__header
        .popup__header-text
          h3.popup__title Prospecto / cliente
        button.popup__close(type="button", data-popup-close, aria-label="Cerrar") ✕
      .popup__body.popup__body--taskframe
        iframe#crm_detail_frame(title="Detalle del prospecto")

  script
    include ../../public/js/core/Popup.js

  script.
    (() => {
      const taskPopup = window.Popup ? new window.Popup({ overlay_selector: "[data-task-popup]" }) : null;
      taskPopup?.iniciar();
      const frame = document.getElementById("task_detail_frame");
      let opened = false;
      window.addEventListener("message", (event) => {
        if (event.data?.type !== "yoayudo:task-height" || !frame) return;
        const max = Math.round(window.innerHeight * 0.82) - 64;
        frame.style.height = `${Math.min(event.data.height, max)}px`;
      });
      document.addEventListener("click", (event) => {
        const trigger = event.target.closest("[data-open-task]");
        if (!trigger || !taskPopup || !frame) return;
        frame.style.height = "440px";
        frame.src = `/admin/tasks/${trigger.dataset.openTask}`;
        opened = true;
        taskPopup.open();
      });
      const overlay = document.querySelector("[data-task-popup]");
      const reloadIfChanged = () => { if (opened) window.location.reload(); };
      overlay?.addEventListener("click", (event) => {
        if (event.target.closest("[data-popup-close]") || event.target === overlay) reloadIfChanged();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && opened && overlay && !overlay.hidden) reloadIfChanged();
      });
    })();

  script.
    (() => {
      // Popup del prospecto/cliente (solo lectura → no recarga al cerrar).
      const crmPopup = window.Popup ? new window.Popup({ overlay_selector: "[data-client-popup]" }) : null;
      crmPopup?.iniciar();
      const frame = document.getElementById("crm_detail_frame");
      window.addEventListener("message", (event) => {
        if (event.data?.type !== "yoayudo:crm-height" || !frame) return;
        const max = Math.round(window.innerHeight * 0.82) - 64;
        frame.style.height = `${Math.min(event.data.height, max)}px`;
      });
      document.addEventListener("click", (event) => {
        const trigger = event.target.closest("[data-open-client]");
        if (!trigger || !crmPopup || !frame) return;
        frame.style.height = "320px";
        frame.src = `/inspector/crm/${trigger.dataset.openClient}`;
        crmPopup.open();
      });
    })();

  script.
    (() => {
      document.addEventListener("click", (event) => {
        const button = event.target.closest(".copy-btn");
        if (!button || !button.dataset.copy || !navigator.clipboard) return;
        navigator.clipboard.writeText(button.dataset.copy).then(() => {
          // Feedback por clase (el CSS cambia el ícono a check); no tocamos el
          // innerHTML para no borrar el SVG.
          button.classList.add("is-copied");
          setTimeout(() => button.classList.remove("is-copied"), 1400);
        }).catch(() => {});
      });

      function closeDetails(except) {
        document.querySelectorAll(".turn-detail:not([hidden])").forEach((detail) => {
          if (detail === except) return;
          detail.hidden = true;
          detail.closest(".turn-actions")?.querySelectorAll(".turn-action-chip[aria-expanded='true']")
            .forEach((chip) => chip.setAttribute("aria-expanded", "false"));
        });
      }

      document.addEventListener("click", (event) => {
        const chip = event.target.closest(".turn-action-chip");
        if (!chip) {
          closeDetails(null);
          return;
        }
        const detail = chip.closest(".turn-actions")?.querySelector(".turn-detail");
        if (!detail) return;
        const willOpen = detail.hidden;
        closeDetails(willOpen ? detail : null);
        detail.hidden = !willOpen;
        chip.closest(".turn-actions").querySelectorAll(".turn-action-chip")
          .forEach((sibling) => sibling.setAttribute("aria-expanded", String(willOpen)));
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeDetails(null);
      });
    })();
