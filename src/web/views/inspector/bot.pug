extends ../layout

block content
  -
    const definition = bot?.definition_json || {};
    const identity = definition.identity || {};
    const conv_pill_class = { ok: "status-executed", warn: "status-pending_provider", idle: "status-blocked" };
    const behavior = definition.behavior || {};
    const interactions = Array.isArray(definition.interactions) ? definition.interactions : [];
    const ai = definition.ai || {};
    const ai_model_options = Array.isArray(ai_models) ? ai_models : [];
    const selected_ai_provider = ai.provider || "openai";
    const selected_ai_model = ai.model || (ai_model_options[0] && ai_model_options[0].model) || "gpt-5.5";
    const selected_ai_model_option = ai_model_options.find((option) => option.provider === selected_ai_provider && option.model === selected_ai_model) || ai_model_options[0] || {};
    const selected_ai_model_option_id = selected_ai_model_option.id || `${selected_ai_provider}:${selected_ai_model}`;
    const supported_channel_rows = Array.isArray(supported_channels) ? supported_channels : [];
    const whatsapp_channel_rows = Array.isArray(whatsapp_channels) ? whatsapp_channels : [];
    const primary_whatsapp_channel = whatsapp_channel_rows[0] || {};
    const instagram_channel_rows = Array.isArray(instagram_channels) ? instagram_channels : [];
    const primary_instagram_channel = instagram_channel_rows[0] || {};
    const human_group_options = Array.isArray(human_groups) ? human_groups : [];
    const human_group_options_json = JSON.stringify(human_group_options).replace(/</g, "\\u003c");
    const is_system_bot = (bot?.bot_type || identity.type) === "system";
    const expected_knowledge = definition.expected_knowledge || "";
    const assigned_knowledge_sources = Array.isArray(knowledge_sources) ? knowledge_sources : [];
    const all_knowledge_sources = Array.isArray(available_knowledge_sources) ? available_knowledge_sources : [];
    const knowledge_ids = Array.isArray(definition.knowledge_source_ids) ? definition.knowledge_source_ids : [];
    const assigned_knowledge_ids = new Set(assigned_knowledge_sources.map((source) => source.id).concat(knowledge_ids));
    const addable_knowledge_sources = all_knowledge_sources.filter((source) => !assigned_knowledge_ids.has(source.id));
    const system_interactions = Array.isArray(available_interactions) ? available_interactions : [];
    const configured_types = new Set(interactions.map((interaction) => interaction.type));
    const addable_interactions = system_interactions.filter((interaction) => !configured_types.has(interaction.type));
    const settings_json = Object.keys(definition).length ? definition : (bot?.settings_json || {});
    const bot_name = identity.name || bot?.name || "Agente no encontrado";
    const bot_description = identity.description || bot?.description || "";
    const bot_goal = identity.goal || definition.goal || "";
    const behavior_language = behavior.language || "es-MX";
    const behavior_tone = behavior.tone || bot?.tono || "professional";
    const operating_instructions = behavior.operating_instructions || bot?.instrucciones_operativas || "";
    const constraints_text = Array.isArray(behavior.constraints) ? behavior.constraints.join("\n") : (behavior.constraints || "");
    const knowledge_type_label = (type) => {
      if (type === "document") return "Documento";
      if (type === "url") return "URL";
      return "Texto";
    };
    const knowledge_preview = (value) => {
      const text = String(value || "").trim();
      if (!text) return "";
      return text.length > 220 ? `${text.slice(0, 220)}...` : text;
    };
    const last_saved_at_iso = bot?.updated_at ? new Date(bot.updated_at).toISOString() : "";
    const svg_open = '<svg class="ui-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">';
    const editor_icons = {
      user: `${svg_open}<circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.6 3.2-5.5 7-5.5s7 1.9 7 5.5"/></svg>`,
      chat: `${svg_open}<path d="M6 5h12a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3.5V7a2 2 0 0 1 2-2z"/></svg>`,
      play: `${svg_open}<circle cx="12" cy="12" r="9"/><path d="M10 8.5l5.5 3.5L10 15.5z" fill="currentColor" stroke="none"/></svg>`,
      book: `${svg_open}<path d="M4 5.5A1.5 1.5 0 0 1 5.5 4H11v15.5H5.5A1.5 1.5 0 0 0 4 21z"/><path d="M20 5.5A1.5 1.5 0 0 0 18.5 4H13v15.5h5.5A1.5 1.5 0 0 1 20 21z"/></svg>`,
      broadcast: `${svg_open}<circle cx="12" cy="12" r="1.8"/><path d="M8.6 8.6a5 5 0 0 0 0 6.8M15.4 8.6a5 5 0 0 1 0 6.8M6.2 6.2a9 9 0 0 0 0 11.6M17.8 6.2a9 9 0 0 1 0 11.6"/></svg>`,
      bolt: `${svg_open}<path d="M13 3L5.5 13H11l-1 8 8.5-11.5H13z"/></svg>`,
      lock: `${svg_open}<rect x="5" y="10.5" width="14" height="9.5" rx="2"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/></svg>`,
      gear: `${svg_open}<circle cx="12" cy="12" r="3"/><path d="M12 2.5v3M12 18.5v3M2.5 12h3M18.5 12h3M5.2 5.2l2.1 2.1M16.7 16.7l2.1 2.1M18.8 5.2l-2.1 2.1M7.3 16.7l-2.1 2.1"/></svg>`,
      globe: `${svg_open}<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.6 2.6 2.6 15.4 0 18M12 3c-2.6 2.6-2.6 15.4 0 18"/></svg>`,
      smiley: `${svg_open}<circle cx="12" cy="12" r="9"/><path d="M8.5 14c.8 1.2 2 1.9 3.5 1.9s2.7-.7 3.5-1.9"/><path d="M9 9.5h.01M15 9.5h.01"/></svg>`,
      sparkles: `${svg_open}<path d="M12 3l1.7 4.3L18 9l-4.3 1.7L12 15l-1.7-4.3L6 9l4.3-1.7z"/><path d="M18.5 14l.7 1.8 1.8.7-1.8.7-.7 1.8-.7-1.8-1.8-.7 1.8-.7z"/></svg>`,
      id_card: `${svg_open}<rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="11" r="2"/><path d="M13 9.5h5M13 13h5M5.5 16c0-1.3 1.3-2 3-2s3 .7 3 2"/></svg>`,
      send: `${svg_open}<path d="M21 3 11 13"/><path d="M21 3l-6.5 18-3.5-8-8-3.5z"/></svg>`,
      headset: `${svg_open}<path d="M5 13a7 7 0 0 1 14 0"/><rect x="3.5" y="13" width="3.5" height="6" rx="1.5"/><rect x="17" y="13" width="3.5" height="6" rx="1.5"/><path d="M19 19v.4a2.6 2.6 0 0 1-2.6 2.6H13"/></svg>`,
      search: `${svg_open}<circle cx="11" cy="11" r="6.5"/><path d="M20 20l-4-4"/></svg>`,
      note: `${svg_open}<path d="M14 3H7a1.5 1.5 0 0 0-1.5 1.5v15A1.5 1.5 0 0 0 7 21h10a1.5 1.5 0 0 0 1.5-1.5V7.5z"/><path d="M14 3v4.5h4.5"/><path d="M9 12.5h6M9 16h6"/></svg>`,
      task: `${svg_open}<rect x="6" y="5" width="12" height="16" rx="1.5"/><path d="M9.5 5V4a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v1"/><path d="M9.5 13l1.8 1.8L15 11"/></svg>`,
      summary: `${svg_open}<rect x="5" y="4" width="14" height="16" rx="1.5"/><path d="M8.5 9h7M8.5 12.5h7M8.5 16h4"/></svg>`,
      trash: `${svg_open}<path d="M5 7h14"/><path d="M9 7V5.5A1.5 1.5 0 0 1 10.5 4h3A1.5 1.5 0 0 1 15 5.5V7"/><path d="M7 7l.8 12.2A1.5 1.5 0 0 0 9.3 20.5h5.4a1.5 1.5 0 0 0 1.5-1.3L17 7"/><path d="M10.5 11v6M13.5 11v6"/></svg>`,
      chevron: `${svg_open}<path d="M6 9.5l6 6 6-6"/></svg>`,
      x: `${svg_open}<path d="M6 6l12 12M18 6L6 18"/></svg>`,
      mic: `${svg_open}<rect x="9" y="3" width="6" height="11" rx="3"/><path d="M5 11a7 7 0 0 0 14 0"/><path d="M12 18v3M9 21h6"/></svg>`,
      cash: `${svg_open}<rect x="3" y="6" width="18" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 9.5h.01M18 14.5h.01"/></svg>`,
      receipt: `${svg_open}<path d="M6 3h12v18l-3-1.5-3 1.5-3-1.5L6 21z"/><path d="M9 8h6M9 12h6"/></svg>`,
      cart: `${svg_open}<circle cx="9.5" cy="20" r="1.3"/><circle cx="17" cy="20" r="1.3"/><path d="M3 4h2l2.4 11.4a1 1 0 0 0 1 .8h8.5a1 1 0 0 0 1-.78L20.5 8H6.2"/></svg>`,
      box: `${svg_open}<path d="M3.5 7.5 12 3l8.5 4.5v9L12 21l-8.5-4.5z"/><path d="M3.5 7.5 12 12l8.5-4.5M12 12v9"/></svg>`,
      code: `${svg_open}<path d="M9 8l-4 4 4 4M15 8l4 4-4 4"/></svg>`,
    };
    const editor_icon = (name) => editor_icons[name] || `${svg_open}<circle cx="12" cy="12" r="9"/></svg>`;
    const interaction_icons = {
      receive_whatsapp_message: "chat",
      send_whatsapp_message: "send",
      consult_human: "headset",
      buscar_negocios: "search",
      guardar_nota: "note",
      crear_tarea: "task",
      generar_resumen: "summary",
      responder_voz: "mic",
      registrar_inicio_dia: "cash",
      registrar_venta: "receipt",
      registrar_compra: "cart",
      registrar_inventario: "box",
      registrar_cierre_dia: "lock",
      registrar_nota_dia: "note",
      generar_reporte_dia: "summary",
    };
    const interaction_icon = (type) => editor_icon(interaction_icons[type] || "bolt");
    const interaction_icon_svgs_json = JSON.stringify(
      Object.fromEntries((Array.isArray(available_interactions) ? available_interactions : []).map((item) => [item.type, interaction_icon(item.type)])),
    ).replace(/</g, "\\u003c");
    const editor_trash_svg_json = JSON.stringify(editor_icon("trash")).replace(/</g, "\\u003c");
    const editor_chevron_svg_json = JSON.stringify(editor_icon("chevron")).replace(/</g, "\\u003c");
    const interaction_options_by_type_json = JSON.stringify(
      Object.fromEntries((Array.isArray(available_interactions) ? available_interactions : []).map((item) => [item.type, item.options || []])),
    ).replace(/</g, "\\u003c");
    // Las tarjetas de interacción usan el único acento de la marca (sin color por categoría):
    // el icono ya distingue cada interacción. Ver DESIGN.md (One Accent Rule).
    const available_interactions_json = JSON.stringify(
      (Array.isArray(available_interactions) ? available_interactions : []).map((item) => ({
        type: item.type,
        label: item.label,
        description: item.description || "",
        placeholder: item.instructions_placeholder || "",
      })),
    ).replace(/</g, "\\u003c");

  mixin icon(name)
    != editor_icon(name)

  mixin section_head(icon_name, title, subtitle)
    div.section-head
      span.section-badge!= editor_icon(icon_name)
      div
        h2= title
        if subtitle
          p.section-sub= subtitle

  if bot
    -
      // /inspector/bots/:id es la vista admin/plataforma; /inspector/bots/:id/business/account
      // es la vista con contexto de cuenta. Un bot de sistema en la vista admin NO
      // muestra business/account (es de la plataforma); sí los muestra en la vista de cuenta.
      const account_scope = typeof show_account_scope !== "undefined" && show_account_scope;
      const show_account_context = account_scope || !is_system_bot;
      const bot_account_url = bot.account_id ? `/dashboard/accounts/${bot.account_id}` : "/dashboard";
      const type_chip_label = is_system_bot ? "Sistema" : "Personalizado";
      const editor_self_path = account_scope ? `/inspector/bots/${bot.id}/business/account` : `/inspector/bots/${bot.id}`;
    if show_account_context
      +breadcrumb([{ label: "Dashboard", href: "/dashboard" }, { label: bot.account_name || "Cuenta", href: bot_account_url }, { label: bot_name }])
    else
      +breadcrumb([{ label: "Inspector", href: "/inspector" }, { label: bot_name }])
    section.page-header.builder-header
      div
        div.builder-title
          input#bot_title_input.builder-title-input(type="text", value=bot_name, aria-label="Nombre del agente", autocomplete="off")
          span(class=`bot-type-chip is-${is_system_bot ? "system" : "custom"}`)= type_chip_label
        if show_account_context
          p= `${bot.organization_name || "Organization"} / ${bot.account_name || "Account"}`
        else
          p Plataforma YoAyudo · Bot de sistema
        if is_system_bot
          if account_scope
            a.entity-link.builder-scope-link(href=`/inspector/bots/${bot.id}`) ← Ver a nivel plataforma
          else
            a.entity-link.builder-scope-link(href=`/inspector/bots/${bot.id}/business/account`) Ver en cuenta (prueba) →
      div.builder-actions
        div#autosave-indicator.autosave-indicator.idle(aria-live="polite", data-saved-at=last_saved_at_iso)
          span.autosave-dot(aria-hidden="true")
          span.autosave-text
          button.autosave-retry(type="button", hidden) Reintentar
        a.activity-link(href=`/inspector/bots/${bot.id}/activity`) Actividad
        button#open_settings_json.json-view-button(type="button")
          span.json-view-button__icon!= editor_icon("code")
          span Ver settings JSON

    //- Popup agnóstico (window.Popup): config cruda del bot, solo lectura. Va en
    //- modal para no romper el layout del header con líneas largas de JSON.
    #settings_json_popup.popup-overlay(
      data-popup-overlay,
      data-popup-overlay-close="true",
      data-settings-json-popup,
      data-autosave-ignore
    )
      .popup.popup--full.popup--default
        .popup__header
          .popup__header-text
            h3.popup__title Settings JSON
            .popup__subtitle Configuración cruda de este agente (solo lectura).
          button.popup__close(type="button", data-popup-close, aria-label="Cerrar")!= editor_icon("x")
        .popup__body
          pre.json-dump= JSON.stringify(settings_json, null, 2)
        .popup__footer
          button.secondary-button(type="button", data-popup-close) Cerrar

    //- Knowledge Center embebido (iframe de la página real) para crear/editar
    //- knowledge sin salir del editor. Al cerrarse, el picker "Asignar knowledge"
    //- y la tabla de asignados se re-leen del server (altas/bajas hechas adentro).
    //- Aplica a ambos tipos: en system bots scopea a la cuenta oficial (prueba).
    #knowledge_center_popup.popup-overlay(
      data-popup-overlay,
      data-popup-overlay-close="true",
      data-knowledge-center-popup,
      data-autosave-ignore
    )
      .popup.popup--full.popup--default
        .popup__header
          .popup__header-text
            h3.popup__title Knowledge Center
            .popup__subtitle Crea y edita knowledge sin salir del editor.
          a.button.secondary-button(href=`/inspector/accounts/${bot.account_id}/knowledge`, target="_blank", rel="noreferrer") Abrir en página
          button.popup__close(type="button", data-popup-close, aria-label="Cerrar")!= editor_icon("x")
        .popup__body.popup__body--frame
          iframe#knowledge_center_frame(data-src=`/inspector/accounts/${bot.account_id}/knowledge`, title="Knowledge Center")

    //- Popup agnóstico (window.Popup): agregar o editar un canal (WhatsApp / Instagram).
    //- Cada tab postea a POST /inspector/bots/:id/channels (reusa el upsert+assign del
    //- autosave) y regresa al editor en la pestaña Canales (?tab=canales).
    #channel_popup.popup-overlay(
      data-popup-overlay,
      data-popup-overlay-close="true",
      data-channel-popup,
      data-autosave-ignore
    )
      .popup.popup--md.popup--default
        .popup__header
          .popup__header-text
            h3.popup__title(data-channel-popup-title) Agregar canal
            .popup__subtitle Conecta el canal por donde te escriben tus clientes.
          button.popup__close(type="button", data-popup-close, aria-label="Cerrar")!= editor_icon("x")
        .popup__body
          .channel-popup-tab-shell.wamy-tabs
            #channel-popup-tabs.tabs(data-initial-tab="whatsapp", role="tablist", aria-label="Tipo de canal")
              button.tab.active(type="button", data-section="whatsapp", role="tab", aria-selected="true") WhatsApp
              button.tab(type="button", data-section="instagram", role="tab", aria-selected="false") Instagram
          .tab-section(data-parent-tab="channel-popup-tabs", data-section="whatsapp")
            form.popup-form(method="post", action=`/inspector/bots/${bot.id}/channels`)
              input(type="hidden", name="channel_type", value="whatsapp")
              input(type="hidden", name="return_to", value=editor_self_path)
              label(for="channel_wa_display") Número de WhatsApp
              input#channel_wa_display(type="tel", name="whatsapp_display_phone_number", placeholder="+52 55 1234 5678", required, autocomplete="off")
              p.field-hint El número con lada que ven tus clientes.
              label(for="channel_wa_meta") ID del número en Meta
              input#channel_wa_meta(type="text", name="whatsapp_phone_number_id", placeholder="1234567890", required, autocomplete="off")
              p.field-hint En Meta WhatsApp Manager → Configuración de la API (phone_number_id).
              .form-actions
                button.secondary-button(type="button", data-popup-close) Cancelar
                button(type="submit") Guardar canal
          .tab-section(data-parent-tab="channel-popup-tabs", data-section="instagram", hidden)
            form.popup-form(method="post", action=`/inspector/bots/${bot.id}/channels`)
              input(type="hidden", name="channel_type", value="instagram")
              input(type="hidden", name="return_to", value=editor_self_path)
              label(for="channel_ig_user") Usuario de Instagram
              input#channel_ig_user(type="text", name="instagram_username", placeholder="@tunegocio", required, autocomplete="off")
              p.field-hint El @usuario que ven tus clientes.
              label(for="channel_ig_meta") ID de la cuenta en Meta
              input#channel_ig_meta(type="text", name="instagram_account_id", placeholder="17841400000000000", required, autocomplete="off")
              p.field-hint En Meta → Instagram (Instagram Business Account ID).
              .form-actions
                button.secondary-button(type="button", data-popup-close) Cancelar
                button(type="submit") Guardar canal

    form(method="post", action=`/inspector/bots/${bot.id}`, id="bot-editor")
      div.bot-editor-tab-shell.wamy-tabs
        div#bot-editor-tabs.tabs(data-initial-tab="identidad", role="tablist", aria-label="Editor de bot")
          button.tab.active(type="button", data-section="identidad", role="tab", aria-selected="true")
            +icon("user")
            span Identidad
          button.tab(type="button", data-section="conversaciones", role="tab", aria-selected="false")
            +icon("chat")
            span Conversaciones
          button.tab(type="button", data-section="probar", role="tab", aria-selected="false")
            +icon("play")
            span Probar
          button.tab(type="button", data-section="knowledge", role="tab", aria-selected="false")
            +icon("book")
            span Knowledge
          button.tab(type="button", data-section="canales", role="tab", aria-selected="false")
            +icon("broadcast")
            span Canales
          button.tab(type="button", data-section="interacciones", role="tab", aria-selected="false")
            +icon("bolt")
            span Interacciones
          button.tab(type="button", data-section="restricciones", role="tab", aria-selected="false")
            +icon("lock")
            span Restricciones

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="identidad")
        +section_head("user", "Identidad del agente", "Define los datos principales y el propósito de este agente.")
        div.form-grid.form-grid--identity
          div
            label(for="name") Nombre
            div.field-control.has-trailing
              input#name(type="text", name="name", value=bot_name)
              span.field-trailing-icon(aria-hidden="true")!= editor_icon("id_card")
          div
            label(for="status") Estado
            div.field-control.has-leading
              span.status-dot(class=`is-${bot.status || identity.status || "draft"}`, aria-hidden="true")
              select#status(name="status")
                each status_option in ["draft", "active", "archived"]
                  option(value=status_option, selected=(bot.status || identity.status) === status_option)= status_option
          div
            label(for="bot_type") Tipo
            select#bot_type(name="bot_type")
              each type_option in ["system", "custom"]
                option(value=type_option, selected=(bot.bot_type || identity.type) === type_option)= type_option
        div.form-grid.form-grid--identity-detail
          div
            label(for="description") Descripción
            textarea#description(name="description", rows="3")= bot_description
          div
            label(for="goal") Objetivo
            textarea#goal(name="goal", rows="3")= bot_goal

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="identidad")
        +section_head("gear", "Instrucciones operativas", "Configura el idioma, tono, modelo y las instrucciones para este agente.")
        div.form-grid.form-grid--operativas
          div
            label(for="behavior_language") Idioma
            div.field-control.has-leading
              span.field-lead-icon(aria-hidden="true")!= editor_icon("globe")
              select#behavior_language(name="behavior_language")
                option(value="es-MX", selected=behavior_language === "es-MX") Español México
                option(value="en-US", selected=behavior_language === "en-US") English US
          div
            label(for="behavior_tone") Tono
            div.field-control.has-leading
              span.field-lead-icon(aria-hidden="true")!= editor_icon("smiley")
              select#behavior_tone(name="behavior_tone")
                option(value="direct", selected=behavior_tone === "direct") Directo
                option(value="friendly", selected=behavior_tone === "friendly") Amable
                option(value="professional", selected=behavior_tone === "professional") Profesional
                option(value="commercial", selected=behavior_tone === "commercial") Comercial
                option(value="technical", selected=behavior_tone === "technical") Técnico
                option(value="casual", selected=behavior_tone === "casual") Casual
          div
            label(for="ai_model_selection") Modelo IA
            div.field-control.has-leading
              span.field-lead-icon(aria-hidden="true")!= editor_icon("sparkles")
              select#ai_model_selection(name="ai_model_selection")
                each model_option in ai_model_options
                  option(value=model_option.id, selected=selected_ai_model_option_id === model_option.id)= model_option.label
        div.field-with-counter
          label(for="instrucciones_operativas") Instrucciones
          textarea#instrucciones_operativas(
            name="instrucciones_operativas",
            rows="8",
            maxlength="2000",
            data-char-counter="instrucciones_counter",
            placeholder="Describe cómo debe operar este agente, qué debe priorizar, cuándo debe preguntar, cómo debe usar knowledge y cuándo debe consultar humanos."
          )= operating_instructions
          span#instrucciones_counter.char-counter(aria-hidden="true")

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="knowledge", hidden)
        if is_system_bot
          //- Bot de sistema: declara el knowledge esperado (contrato para quien lo
          //- instale) y, aparte, puede asignar knowledge de la cuenta oficial de
          //- YoAyudo SOLO para probarlo. Al clonarse a una cuenta, el clon no
          //- copia ninguna fuente (clone_bot deja knowledge_source_ids vacío).
          +section_head("book", "Knowledge esperado", "Este es un bot de sistema: describe el knowledge que un negocio debería proveer al instalarlo.")
          div.field-with-counter
            label(for="expected_knowledge") Knowledge esperado
            textarea#expected_knowledge(
              name="expected_knowledge",
              rows="6",
              maxlength="2000",
              data-char-counter="expected_knowledge_counter",
              placeholder="Ej. Catálogo de productos con precios, políticas de envío y devoluciones, FAQ de soporte, horarios y ubicaciones."
            )= expected_knowledge
            span#expected_knowledge_counter.char-counter(aria-hidden="true")
          div.section-title.knowledge-test-head
            div
              h3.panel-subhead Knowledge para probar
              p.meta Fuentes de la cuenta oficial de YoAyudo, solo para probar este bot. Al clonarlo a una cuenta no se copia ninguna.
            a#open_knowledge_center.button.secondary-button(href=`/inspector/accounts/${bot.account_id}/knowledge`) Ir a Knowledge Center
        else
          div.section-title
            +section_head("book", "Knowledge", "Fuentes de conocimiento que el agente puede usar para responder.")
            a#open_knowledge_center.button.secondary-button(href=`/inspector/accounts/${bot.account_id}/knowledge`) Ir a Knowledge Center
        //- Picker y botón siempre presentes (deshabilitados si no hay nada que
        //- asignar): el popup del Knowledge Center los repobla al cerrarse.
        div.inline-add-row
          select#knowledge_source_picker(disabled=!addable_knowledge_sources.length)
            if addable_knowledge_sources.length
              option(value="") Selecciona knowledge existente
              each source in addable_knowledge_sources
                option(value=source.id, data-name=source.name, data-type=source.source_type, data-status=source.status, data-summary=source.summary || "")= source.name
            else
              option Todo el knowledge disponible ya está asignado
          button#add_knowledge_source(type="button", disabled=!addable_knowledge_sources.length) Asignar knowledge
        div#knowledge_assigned_area
          if assigned_knowledge_sources.length
            div.table-wrap#assigned_knowledge_table
              table
                thead
                  tr
                    th Fuente
                    th Tipo
                    th Estado
                    th Knowledge
                    th
                tbody
                  each source in assigned_knowledge_sources
                    tr
                      td
                        strong= source.name
                        if source.description
                          p.meta= source.description
                        input(type="hidden", name="knowledge_source_ids", value=source.id)
                      td= knowledge_type_label(source.source_type)
                      td
                        span.status= source.status
                      td
                        if source.summary_status
                          span.status= source.summary_status
                        if source.summary
                          p.meta= knowledge_preview(source.summary)
                      td
                        button.secondary-button.knowledge-remove(
                          type="button",
                          data-id=source.id,
                          data-name=source.name,
                          data-type=source.source_type,
                          data-status=source.status,
                          data-summary=source.summary || "",
                          title="Quitar knowledge de este agente"
                        ) Quitar
          else
            div.empty#knowledge_empty_state Este agente todavía no tiene knowledge asignado. Selecciona una fuente existente o créala en Knowledge Center.
            div#assigned_knowledge_hidden
              each knowledge_id in knowledge_ids
                input(type="hidden", name="knowledge_source_ids", value=knowledge_id)

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="canales", hidden)
        div.section-title
          +section_head("broadcast", "Canales", "Conecta los canales por donde te escriben tus clientes.")
          button#open_add_channel.button(type="button") Agregar canal
        if whatsapp_channel_rows.length || instagram_channel_rows.length
          div.channel-list
            each whatsapp_channel in whatsapp_channel_rows
              div.channel-row
                span.channel-icon.channel-icon--whatsapp(aria-hidden="true") WA
                div.channel-row__main
                  div.channel-row__title= whatsapp_channel.display_phone_number || "Sin número"
                  div.channel-row__meta WhatsApp · ID Meta: #{whatsapp_channel.phone_number_id}
                span(class=`channel-status ${whatsapp_channel.status === "active" ? "is-connected" : "is-idle"}`)= whatsapp_channel.status === "active" ? "Conectado" : (whatsapp_channel.status || "Sin conectar")
                button.secondary-button.channel-edit(
                  type="button",
                  data-channel-type="whatsapp",
                  data-display=whatsapp_channel.display_phone_number || "",
                  data-meta-id=whatsapp_channel.phone_number_id || ""
                ) Editar
            each instagram_channel in instagram_channel_rows
              div.channel-row
                span.channel-icon.channel-icon--instagram(aria-hidden="true")
                  svg.channel-glyph(viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                    rect(x="3.5", y="3.5", width="17", height="17", rx="5")
                    circle(cx="12", cy="12", r="4")
                    circle(cx="17.2", cy="6.8", r="1.1", fill="currentColor", stroke="none")
                div.channel-row__main
                  div.channel-row__title= instagram_channel.username ? `@${instagram_channel.username}` : "Sin usuario"
                  div.channel-row__meta Instagram · ID Meta: #{instagram_channel.external_account_id}
                span(class=`channel-status ${instagram_channel.status === "active" ? "is-connected" : "is-idle"}`)= instagram_channel.status === "active" ? "Conectado" : (instagram_channel.status || "Sin conectar")
                button.secondary-button.channel-edit(
                  type="button",
                  data-channel-type="instagram",
                  data-username=instagram_channel.username || "",
                  data-meta-id=instagram_channel.external_account_id || ""
                ) Editar
        else
          div.empty Aún no hay canales conectados. Usa "Agregar canal" para conectar WhatsApp o Instagram.

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="interacciones", hidden)
        +section_head("bolt", "Interacciones", "Lo que el agente puede hacer y cómo. Cada interacción tiene su propio prompt que define cuándo y cómo usarla.")
        div.interaction-toolbar
          button#toggle_all_interactions.toggle-all(type="button")
            span.toggle-all-icon(aria-hidden="true")!= editor_icon("chevron")
            span.toggle-all-label Expandir todos
        input(type="hidden", name="interactions_present", value="1")
        if interactions.length
          div.interaction-grid
            each interaction, index in interactions
              -
                const system_interaction = system_interactions.find((item) => item.type === interaction.type) || interaction;
              div.interaction-card.is-collapsed(
                data-type=system_interaction.type,
                data-label=system_interaction.label || interaction.label,
                data-description=system_interaction.description || "",
                data-placeholder=system_interaction.instructions_placeholder || "",
                class=(interaction.enabled === false ? "is-disabled" : "")
              )
                input(type="hidden", name="interaction_type", value=system_interaction.type)
                div.interaction-card-head
                  span.interaction-icon!= interaction_icon(system_interaction.type)
                  div.interaction-card-titles
                    h3= system_interaction.label || interaction.label
                    if system_interaction.description
                      p.meta= system_interaction.description
                  div.interaction-card-controls
                    label.interaction-switch
                      input(type="checkbox", name="interaction_enabled", value=index, checked=interaction.enabled !== false)
                      span.switch-track(aria-hidden="true")
                      span.switch-label Habilitada
                    button.interaction-remove(type="button", title="Quitar interacción", aria-label="Quitar interacción")!= editor_icon("trash")
                    button.interaction-collapse(type="button", aria-label="Mostrar u ocultar instrucciones", aria-expanded="false")!= editor_icon("chevron")
                div.interaction-card-body
                  label.interaction-field-label Instrucciones
                  textarea(
                    name="interaction_instructions",
                    rows="4",
                    placeholder=system_interaction.instructions_placeholder || "Describe cuándo y cómo debe usar esta interacción."
                  )= interaction.instructions || ""
                  if (system_interaction.options || []).length
                    div.interaction-options
                      each option in system_interaction.options
                        - const option_on = !!(interaction.options && interaction.options[option.key]);
                        label.interaction-switch.interaction-option
                          input(type="checkbox", name=`interaction_option_${option.key}`, value=index, checked=option_on)
                          span.switch-track(aria-hidden="true")
                          span.interaction-option-text
                            span.interaction-option-label= option.label
                            if option.description
                              span.interaction-option-desc= option.description
                  if interaction.type === "consult_human"
                    -
                      const selected_group_ids = Array.isArray(interaction.human_group_ids)
                        ? interaction.human_group_ids.filter((id) => human_group_options.some((group) => group.id === id))
                        : [];
                    label Grupos humanos
                    //- Multi-select: cada grupo es un checkbox sin name; el hidden input
                    //- (uno por interacción) lleva los ids comma-joined que el server parsea.
                    div.human-group-multi
                      each group in human_group_options
                        label.human-group-option
                          input(type="checkbox", data-human-group, value=group.id, checked=selected_group_ids.includes(group.id))
                          span= group.label
                      input(type="hidden", name="interaction_human_group_ids", value=selected_group_ids.join(","))
                    p.config-warning(hidden=selected_group_ids.length > 0) Sin grupo humano asignado: el agente no sabrá a quién escalar.
                  else
                    input(type="hidden", name="interaction_human_group_ids", value="")
        div.empty#interaction_empty_state(hidden=interactions.length > 0) Ninguna interacción configurada.

        div.inline-add-row.inline-add-row--single
          button#open_interaction_picker(type="button", disabled=!addable_interactions.length) Agregar interacción

        div#new_interaction_mount

        //- Popup agnóstico (window.Popup): elegir una o más interacciones con su descripción.
        #interaction_picker_popup.popup-overlay(
          data-popup-overlay,
          data-popup-overlay-close="true",
          data-interaction-picker-popup,
          data-autosave-ignore
        )
          .popup.popup--lg.popup--default
            .popup__header
              .popup__header-text
                h3.popup__title Agregar interacciones
                .popup__subtitle Elige una o más interacciones para este agente.
              button.popup__close(type="button", data-popup-close, aria-label="Cerrar")!= editor_icon("x")
            .popup__body
              input#interaction_picker_search.interaction-picker-search(type="search", placeholder="Buscar interacción...", aria-label="Buscar interacción", autocomplete="off")
              div#interaction_picker_list.interaction-picker-list
              div.empty#interaction_picker_empty(hidden) Tienes todas las interacciones conectadas.
              div.empty#interaction_picker_no_match(hidden) Sin interacciones que coincidan con la búsqueda.
            .popup__footer
              button.secondary-button#interaction_picker_cancel(type="button", data-popup-close) Cancelar
              button#interaction_picker_confirm(type="button", disabled) Agregar seleccionadas

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="restricciones", hidden)
        +section_head("lock", "Restricciones", "Qué no debe prometer el agente, cuándo detenerse y cuándo escalar a un humano.")
        div.field-with-counter
          textarea(
            name="constraints_text",
            rows="6",
            maxlength="2000",
            data-char-counter="constraints_counter",
            placeholder="Describe las restricciones del agente: qué no debe prometer, cuándo debe detenerse y cuándo debe consultar a un humano."
          )= constraints_text
          span#constraints_counter.char-counter(aria-hidden="true")

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="probar", hidden)
        +section_head("play", "Probar bot", "Envía un mensaje de prueba y mira cómo responde el agente.")
        div.test-bot-panel(
          data-autosave-ignore,
          data-bot-id=bot.id,
          data-organization-id=bot.organization_id || "",
          data-account-id=bot.account_id || ""
        )
          label(for="test_bot_message") Mensaje de prueba
          textarea#test_bot_message(
            rows="5",
            placeholder="Escribe un mensaje como si llegara por WhatsApp. Ej. Consulta a humano si podemos prometer llamadas automáticas y crea una tarea de seguimiento."
          )
          button#run_bot_test(type="button") Probar bot
          div#bot_test_result.test-result(hidden)

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="conversaciones", hidden)
        +section_head("chat", "Conversaciones recientes", "Las conversaciones más recientes de este agente.")
        if conversations.length
          ul.conv-list
            each conversation in conversations
              li
                a.conv-row(href=(bot.account_id ? `/inspector/accounts/${bot.account_id}/conversations/${conversation.id}` : `/inspector/conversations/${conversation.id}`))
                  div.conv-row__main
                    div.conv-row__head
                      span.conv-row__title= conversation.summary.title
                      if conversation.summary.subtitle
                        span.conv-row__phone= conversation.summary.subtitle
                    span.conv-row__preview= conversation.summary.preview
                  div.conv-row__aside
                    span.conv-row__time= conversation.summary.relative_time
                    div.conv-row__pills
                      if conversation.summary.needs_human
                        span.status-pill.status-pending_provider Atención humana
                      span(class=`status-pill ${conv_pill_class[conversation.summary.status_tone] || "status-blocked"}`)= conversation.summary.status_label
        else
          div.empty Sin conversaciones recientes.
  else
    section.page-header
      h1 Agente no encontrado
      p No se encontró el bot solicitado.

  script
    include ../../public/js/core/Popup.js

  script.
    (() => {
      const openInteractionButton = document.getElementById("open_interaction_picker");
      const interactionMount = document.getElementById("new_interaction_mount");
      const humanGroupOptions = !{human_group_options_json};
      const interactionIconSvgs = !{interaction_icon_svgs_json};
      const interactionTrashSvg = !{editor_trash_svg_json};
      const interactionChevronSvg = !{editor_chevron_svg_json};
      const interactionOptionsByType = !{interaction_options_by_type_json};
      const availableInteractions = !{available_interactions_json};
      const interactionPickerList = document.getElementById("interaction_picker_list");
      const interactionPickerEmpty = document.getElementById("interaction_picker_empty");
      const interactionPickerNoMatch = document.getElementById("interaction_picker_no_match");
      const interactionPickerSearch = document.getElementById("interaction_picker_search");
      const interactionPickerConfirm = document.getElementById("interaction_picker_confirm");
      const interactionPopup = window.Popup
        ? new window.Popup({ overlay_selector: "[data-interaction-picker-popup]" })
        : null;
      interactionPopup?.iniciar();

      const settingsJsonPopup = window.Popup
        ? new window.Popup({ overlay_selector: "[data-settings-json-popup]" })
        : null;
      settingsJsonPopup?.iniciar();
      document
        .getElementById("open_settings_json")
        ?.addEventListener("click", () => settingsJsonPopup?.open());

      // Edición inline del nombre desde el header: el título vive fuera del form,
      // así que espeja al input canónico #name (en Identidad) y dispara su evento
      // input para reusar el autosave. #name de vuelta espeja al título.
      const botTitleInput = document.getElementById("bot_title_input");
      const botNameInput = document.getElementById("name");
      function sizeBotTitle() {
        if (botTitleInput) botTitleInput.size = Math.max((botTitleInput.value || "").length + 1, 8);
      }
      botTitleInput?.addEventListener("input", () => {
        sizeBotTitle();
        if (!botNameInput) return;
        botNameInput.value = botTitleInput.value;
        // El título vive fuera del form; se pide el guardado por la API del autosave
        // (que serializa el form en vivo, ya con #name actualizado).
        window.bot_editor_autosave?.request_save({
          control: { name: "name", tag: "input", value: botTitleInput.value },
          event: { type: "rename" },
        });
      });
      botNameInput?.addEventListener("input", () => {
        if (botTitleInput && document.activeElement !== botTitleInput) {
          botTitleInput.value = botNameInput.value;
          sizeBotTitle();
        }
      });
      sizeBotTitle();

      const knowledgeCenterPopup = window.Popup
        ? new window.Popup({ overlay_selector: "[data-knowledge-center-popup]" })
        : null;
      knowledgeCenterPopup?.iniciar();
      const knowledgeCenterFrame = document.getElementById("knowledge_center_frame");

      // Click simple = popup; con modificador (cmd/ctrl/shift) o sin Popup
      // disponible se respeta el href y abre la página completa.
      document.getElementById("open_knowledge_center")?.addEventListener("click", (event) => {
        if (!knowledgeCenterPopup || !knowledgeCenterFrame) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        event.preventDefault();
        if (!knowledgeCenterFrame.getAttribute("src")) {
          knowledgeCenterFrame.src = knowledgeCenterFrame.dataset.src;
        }
        knowledgeCenterPopup.open();
      });

      function renderHumanGroupSelect(selectedIds = []) {
        const selected = new Set(selectedIds);
        const boxes = humanGroupOptions
          .map(
            (group) =>
              `<label class="human-group-option"><input type="checkbox" data-human-group value="${escapeHtml(group.id)}"${selected.has(group.id) ? " checked" : ""}><span>${escapeHtml(group.label)}</span></label>`,
          )
          .join("");
        const warningHidden = selected.size > 0 ? " hidden" : "";
        return `<label>Grupos humanos</label><div class="human-group-multi">${boxes}<input type="hidden" name="interaction_human_group_ids" value="${escapeHtml([...selected].join(","))}"></div><p class="config-warning"${warningHidden}>Sin grupo humano asignado: el agente no sabrá a quién escalar.</p>`;
      }

      // Interactions already on the bot (read live from the grid) are excluded,
      // so the picker always offers only what's left to add.
      function addableInteractions() {
        const configuredTypes = new Set(
          Array.from(document.querySelectorAll(".interaction-card")).map((card) => card.dataset.type),
        );
        return availableInteractions.filter((item) => !configuredTypes.has(item.type));
      }

      function refreshOpenInteractionButton() {
        if (openInteractionButton) openInteractionButton.disabled = addableInteractions().length === 0;
      }

      function updateInteractionPickerConfirm() {
        if (!interactionPickerConfirm) return;
        const count = interactionPickerList
          ? interactionPickerList.querySelectorAll(".interaction-pick-input:checked").length
          : 0;
        interactionPickerConfirm.disabled = count === 0;
        interactionPickerConfirm.textContent = count > 0 ? `Agregar (${count})` : "Agregar seleccionadas";
      }

      function renderInteractionPickerList() {
        if (!interactionPickerList) return;
        const addable = addableInteractions();
        if (interactionPickerEmpty) interactionPickerEmpty.hidden = addable.length > 0;
        interactionPickerList.innerHTML = addable
          .map((item) => {
            const iconSvg = interactionIconSvgs[item.type] || "";
            const search = `${item.label} ${item.description || ""}`.toLowerCase();
            return `
              <label class="interaction-pick" data-search="${escapeHtml(search)}">
                <input type="checkbox" class="interaction-pick-input"
                  data-type="${escapeHtml(item.type)}"
                  data-label="${escapeHtml(item.label)}"
                  data-description="${escapeHtml(item.description)}"
                  data-placeholder="${escapeHtml(item.placeholder)}">
                <span class="interaction-pick-icon">${iconSvg}</span>
                <span class="interaction-pick-text">
                  <span class="interaction-pick-label">${escapeHtml(item.label)}</span>
                  ${item.description ? `<span class="interaction-pick-desc">${escapeHtml(item.description)}</span>` : ""}
                </span>
              </label>`;
          })
          .join("");
        filterInteractionPickerList();
        updateInteractionPickerConfirm();
      }

      // Filtra las tarjetas por texto (label + descripción). No toca el estado de
      // los checkboxes: una marca puede quedar oculta y se agrega igual al confirmar.
      function filterInteractionPickerList() {
        if (!interactionPickerList) return;
        const query = (interactionPickerSearch?.value || "").trim().toLowerCase();
        const cards = Array.from(interactionPickerList.querySelectorAll(".interaction-pick"));
        let visible = 0;
        for (const card of cards) {
          const match = !query || (card.dataset.search || "").includes(query);
          card.hidden = !match;
          if (match) visible += 1;
        }
        // "Sin coincidencias" solo cuando hay tarjetas pero el filtro las ocultó todas;
        // si no hay ninguna addable, manda el estado vacío original.
        if (interactionPickerNoMatch) interactionPickerNoMatch.hidden = !(cards.length > 0 && visible === 0);
      }

      function getOrCreateInteractionGrid() {
        let grid = document.querySelector(".interaction-grid");
        if (!grid) {
          grid = document.createElement("div");
          grid.className = "interaction-grid";
          if (interactionMount) interactionMount.before(grid);
        }
        return grid;
      }

      // interaction_enabled checkbox values are positional indexes the server reads
      // back; keep them in sync with DOM order after any add/remove.
      function reindexInteractions() {
        document.querySelectorAll(".interaction-card").forEach((card, position) => {
          card
            .querySelectorAll('input[name="interaction_enabled"], input[name^="interaction_option_"]')
            .forEach((checkbox) => {
              checkbox.value = String(position);
            });
        });
      }

      function refreshInteractionEmptyState() {
        const count = document.querySelectorAll(".interaction-card").length;
        let emptyEl = document.getElementById("interaction_empty_state");
        if (count === 0) {
          if (!emptyEl) {
            emptyEl = document.createElement("div");
            emptyEl.className = "empty";
            emptyEl.id = "interaction_empty_state";
            emptyEl.textContent = "Ninguna interacción configurada.";
            const addRow = document.querySelector('.tab-section[data-section="interacciones"] .inline-add-row');
            if (addRow) addRow.before(emptyEl);
          }
          emptyEl.hidden = false;
        } else if (emptyEl) {
          emptyEl.hidden = true;
        }
      }

      function buildInteractionCard({ type, label, description, placeholder, enabled = true }) {
        const card = document.createElement("div");
        card.className = "interaction-card" + (enabled ? "" : " is-disabled");
        card.dataset.type = type;
        card.dataset.label = label || "";
        card.dataset.description = description || "";
        card.dataset.placeholder = placeholder || "";
        const iconSvg = interactionIconSvgs[type] || "";
        const humanField =
          type === "consult_human"
            ? renderHumanGroupSelect()
            : '<input type="hidden" name="interaction_human_group_ids" value="">';
        const options = interactionOptionsByType[type] || [];
        const optionsHtml = options.length
          ? `<div class="interaction-options">${options
              .map(
                (option) => `
                <label class="interaction-switch interaction-option">
                  <input type="checkbox" name="interaction_option_${escapeHtml(option.key)}" value="0">
                  <span class="switch-track" aria-hidden="true"></span>
                  <span class="interaction-option-text">
                    <span class="interaction-option-label">${escapeHtml(option.label)}</span>
                    ${option.description ? `<span class="interaction-option-desc">${escapeHtml(option.description)}</span>` : ""}
                  </span>
                </label>`,
              )
              .join("")}</div>`
          : "";
        card.innerHTML = `
          <input type="hidden" name="interaction_type" value="${escapeHtml(type)}">
          <div class="interaction-card-head">
            <span class="interaction-icon">${iconSvg}</span>
            <div class="interaction-card-titles">
              <h3>${escapeHtml(label)}</h3>
              ${description ? `<p class="meta">${escapeHtml(description)}</p>` : ""}
            </div>
            <div class="interaction-card-controls">
              <label class="interaction-switch">
                <input type="checkbox" name="interaction_enabled" value="0" ${enabled ? "checked" : ""}>
                <span class="switch-track" aria-hidden="true"></span>
                <span class="switch-label">Habilitada</span>
              </label>
              <button class="interaction-remove" type="button" title="Quitar interacción" aria-label="Quitar interacción">${interactionTrashSvg}</button>
              <button class="interaction-collapse" type="button" aria-label="Mostrar u ocultar instrucciones" aria-expanded="true">${interactionChevronSvg}</button>
            </div>
          </div>
          <div class="interaction-card-body">
            <label class="interaction-field-label">Instrucciones</label>
            <textarea name="interaction_instructions" rows="4" placeholder="${escapeHtml(placeholder || "")}"></textarea>
            ${optionsHtml}
            ${humanField}
          </div>
        `;
        return card;
      }

      openInteractionButton?.addEventListener("click", () => {
        if (interactionPickerSearch) interactionPickerSearch.value = "";
        renderInteractionPickerList();
        interactionPopup?.open();
        interactionPickerSearch?.focus();
      });

      interactionPickerSearch?.addEventListener("input", filterInteractionPickerList);

      interactionPickerList?.addEventListener("change", (event) => {
        if (event.target.classList?.contains("interaction-pick-input")) updateInteractionPickerConfirm();
      });

      interactionPickerConfirm?.addEventListener("click", () => {
        if (!interactionPickerList) return;
        const picks = Array.from(interactionPickerList.querySelectorAll(".interaction-pick-input:checked"));
        if (!picks.length) return;
        const grid = getOrCreateInteractionGrid();
        let lastCard = null;
        picks.forEach((input) => {
          const card = buildInteractionCard({
            type: input.dataset.type,
            label: input.dataset.label,
            description: input.dataset.description,
            placeholder: input.dataset.placeholder || "Describe cuándo y cómo debe usar esta interacción.",
            enabled: true,
          });
          grid.appendChild(card);
          lastCard = card;
        });
        reindexInteractions();
        refreshInteractionEmptyState();
        refreshToggleAll();
        refreshOpenInteractionButton();
        interactionPopup?.close();
        lastCard?.scrollIntoView({ block: "nearest", behavior: "smooth" });
        window.bot_editor_autosave?.request_save({
          control: {
            name: "interaction_type",
            tag: "button",
            value: picks.map((input) => input.dataset.type).join(","),
          },
          event: { type: "add_interaction" },
        });
      });

      const interactionsSection = document.querySelector('.tab-section[data-section="interacciones"]');
      const toggleAllButton = document.getElementById("toggle_all_interactions");

      function setCardCollapsed(card, collapsed) {
        card.classList.toggle("is-collapsed", collapsed);
        const chevron = card.querySelector(".interaction-collapse");
        if (chevron) chevron.setAttribute("aria-expanded", String(!collapsed));
      }

      function refreshToggleAll() {
        if (!toggleAllButton) return;
        const cards = [...document.querySelectorAll(".interaction-card")];
        toggleAllButton.hidden = cards.length === 0;
        const allCollapsed = cards.length > 0 && cards.every((card) => card.classList.contains("is-collapsed"));
        toggleAllButton.dataset.mode = allCollapsed ? "expand" : "collapse";
        toggleAllButton.classList.toggle("is-open", !allCollapsed);
        const label = toggleAllButton.querySelector(".toggle-all-label");
        if (label) label.textContent = allCollapsed ? "Expandir todos" : "Compactar todos";
      }

      toggleAllButton?.addEventListener("click", () => {
        const expand = toggleAllButton.dataset.mode === "expand";
        document.querySelectorAll(".interaction-card").forEach((card) => setCardCollapsed(card, !expand));
        refreshToggleAll();
      });

      interactionsSection?.addEventListener("click", (event) => {
        const removeButton = event.target.closest(".interaction-remove");
        if (removeButton) {
          const card = removeButton.closest(".interaction-card");
          if (!card) return;
          const instructions = card.querySelector('textarea[name="interaction_instructions"]');
          const hasText = Boolean(instructions && instructions.value.trim());
          if (hasText && !window.confirm("¿Quitar esta interacción? Se perderá su prompt.")) return;
          const removedType = card.dataset.type;
          card.remove();
          reindexInteractions();
          refreshInteractionEmptyState();
          refreshToggleAll();
          refreshOpenInteractionButton();
          window.bot_editor_autosave?.request_save({
            control: { name: "interaction_type", tag: "button", value: removedType },
            event: { type: "remove_interaction" },
          });
          return;
        }

        // Expand/collapse: chevron button, or clicking the header (but not the switch).
        const head = event.target.closest(".interaction-card-head");
        if (head && !event.target.closest(".interaction-switch")) {
          const card = head.closest(".interaction-card");
          if (!card) return;
          setCardCollapsed(card, !card.classList.contains("is-collapsed"));
          refreshToggleAll();
        }
      });

      // Dim a card live when its "Habilitada" toggle is turned off.
      interactionsSection?.addEventListener("change", (event) => {
        const checkbox = event.target;
        if (!(checkbox instanceof HTMLInputElement) || checkbox.name !== "interaction_enabled") return;
        const card = checkbox.closest(".interaction-card");
        if (card) card.classList.toggle("is-disabled", !checkbox.checked);
      });

      // Multi-select de grupos humanos: al togglear un checkbox, recomputa el hidden
      // input (comma-joined, uno por interacción) y autosava. El warning se muestra
      // cuando no queda ningún grupo seleccionado.
      interactionsSection?.addEventListener("change", (event) => {
        const groupCheckbox = event.target.closest?.("[data-human-group]");
        if (!groupCheckbox) return;
        const wrap = groupCheckbox.closest(".human-group-multi");
        const hidden = wrap?.querySelector('input[type="hidden"][name="interaction_human_group_ids"]');
        if (!wrap || !hidden) return;
        const ids = Array.from(wrap.querySelectorAll("[data-human-group]:checked")).map((box) => box.value);
        hidden.value = ids.join(",");
        const warning = wrap.parentElement?.querySelector(".config-warning");
        if (warning) warning.hidden = ids.length > 0;
        window.bot_editor_autosave?.request_save({
          control: { name: "interaction_human_group_ids", tag: "input", value: hidden.value },
          event: { type: "human_groups" },
        });
      });

      refreshToggleAll();
      refreshOpenInteractionButton();

      const knowledgePicker = document.getElementById("knowledge_source_picker");
      const addKnowledgeButton = document.getElementById("add_knowledge_source");

      function syncKnowledgePicker() {
        if (!knowledgePicker || !addKnowledgeButton) return;
        const hasOptions = Array.from(knowledgePicker.options).some((option) => option.value);
        knowledgePicker.disabled = !hasOptions;
        addKnowledgeButton.disabled = !hasOptions;
        if (!hasOptions) {
          knowledgePicker.innerHTML = "<option>Todo el knowledge disponible ya está asignado</option>";
        }
      }

      // El popup edita knowledge fuera de este form: al cerrarse, picker y tabla
      // de asignados se re-leen del server para reflejar altas/bajas/renombres.
      async function refreshKnowledgeFromServer() {
        try {
          const response = await fetch(window.location.pathname, { headers: { accept: "text/html" } });
          if (!response.ok) return;
          const fresh = new DOMParser().parseFromString(await response.text(), "text/html");
          const freshPicker = fresh.getElementById("knowledge_source_picker");
          if (freshPicker && knowledgePicker) {
            knowledgePicker.innerHTML = freshPicker.innerHTML;
            knowledgePicker.value = "";
          }
          const freshAssigned = fresh.getElementById("knowledge_assigned_area");
          const assignedArea = document.getElementById("knowledge_assigned_area");
          if (freshAssigned && assignedArea) {
            assignedArea.innerHTML = freshAssigned.innerHTML;
            // Los hidden agregados al form por "Asignar knowledge" ya vienen como
            // fila del server tras el autosave: quitar el duplicado suelto.
            document.querySelectorAll('#bot-editor > input[name="knowledge_source_ids"]').forEach((input) => {
              if (assignedArea.querySelector(`input[name="knowledge_source_ids"][value="${input.value}"]`)) input.remove();
            });
          }
          syncKnowledgePicker();
        } catch {
          // Sin red no hay refresh; el picker conserva las opciones actuales.
        }
      }

      if (knowledgeCenterPopup) {
        const closeKnowledgeCenterPopup = knowledgeCenterPopup.close.bind(knowledgeCenterPopup);
        knowledgeCenterPopup.close = () => {
          const wasOpen = knowledgeCenterPopup.is_open();
          closeKnowledgeCenterPopup();
          if (wasOpen) refreshKnowledgeFromServer();
        };
      }

      // Quitar knowledge asignado: delegado en el área (el popup puede reemplazar
      // su innerHTML, el contenedor persiste). El form completo es la verdad:
      // sin hidden inputs el autosave persiste la lista vacía.
      document.getElementById("knowledge_assigned_area")?.addEventListener("click", (event) => {
        const removeButton = event.target.closest(".knowledge-remove");
        if (!removeButton) return;
        const sourceId = removeButton.dataset.id;
        if (knowledgePicker) {
          const hasValueOptions = Array.from(knowledgePicker.options).some((option) => option.value);
          if (!hasValueOptions) {
            knowledgePicker.innerHTML = '<option value="">Selecciona knowledge existente</option>';
          }
          const option = document.createElement("option");
          option.value = sourceId;
          option.textContent = removeButton.dataset.name || "Knowledge";
          option.dataset.name = removeButton.dataset.name || "";
          option.dataset.type = removeButton.dataset.type || "";
          option.dataset.status = removeButton.dataset.status || "";
          option.dataset.summary = removeButton.dataset.summary || "";
          knowledgePicker.appendChild(option);
        }
        document
          .querySelectorAll(`#bot-editor input[name="knowledge_source_ids"][value="${sourceId}"]`)
          .forEach((input) => input.remove());
        removeButton.closest("tr")?.remove();
        syncKnowledgePicker();
        window.bot_editor_autosave?.request_save({
          control: { name: "knowledge_source_ids", tag: "button", value: sourceId },
          event: { type: "remove_knowledge_source" },
        });
      });

      addKnowledgeButton?.addEventListener("click", async () => {
        const option = knowledgePicker.selectedOptions[0];
        if (!option?.value) return;
        const hidden = document.createElement("input");
        hidden.type = "hidden";
        hidden.name = "knowledge_source_ids";
        hidden.value = option.value;
        // Los mounts viven dentro de #knowledge_assigned_area (que el popup puede
        // reemplazar): se buscan al momento, no se capturan al cargar.
        (document.getElementById("assigned_knowledge_hidden") || document.getElementById("bot-editor")).appendChild(hidden);
        document.getElementById("knowledge_empty_state")?.remove();
        option.remove();
        knowledgePicker.value = "";
        syncKnowledgePicker();
        // Tras guardar, re-leer del server para PINTAR la fila asignada en la tabla
        // (el handler solo agrega el hidden input; la fila visible viene del render).
        await window.bot_editor_autosave?.request_save({
          control: { name: "knowledge_source_ids", tag: "button", value: hidden.value },
          event: { type: "add_knowledge_source" },
        });
        await refreshKnowledgeFromServer();
      });

      syncKnowledgePicker();

      const testPanel = document.querySelector(".test-bot-panel");
      const testButton = document.getElementById("run_bot_test");
      const testMessage = document.getElementById("test_bot_message");
      const testResult = document.getElementById("bot_test_result");

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function renderList(title, items, mapper) {
        const rows = (items || []).map(mapper).join("");
        return `<section class="test-result-section"><h3>${title}</h3>${rows || '<p class="meta">Sin registros.</p>'}</section>`;
      }

      function interactionStatusClass(status) {
        const value = String(status || "");
        if (["executed", "mock_received", "mock_sent", "mock_requested_and_answered"].includes(value)) return "ok";
        if (value.startsWith("pending")) return "pending";
        if (value === "ignored") return "muted";
        return "blocked";
      }

      // The "Interacciones" panel is the hero of the test result: it shows the full
      // ordered set the router fired (recibir -> N acciones -> consultar -> enviar),
      // so you can see this bot trigger MORE THAN ONE interaction per message.
      function renderInteractionTrace(trace) {
        const items = Array.isArray(trace) ? trace : [];
        const fired = items.filter((event) => event.status !== "ignored");
        const countLabel = fired.length === 1 ? "1 interacción disparada" : `${fired.length} interacciones disparadas`;
        const rows = items
          .map((event) => `
            <div class="interaction-trace-row is-${interactionStatusClass(event.status)}">
              <span class="interaction-trace-label"><span class="trace-dot" aria-hidden="true"></span>${escapeHtml(event.label || event.interaction_type)}</span>
              <span class="interaction-trace-status">${escapeHtml(event.status)}</span>
              ${event.reason ? `<p class="interaction-trace-reason">${escapeHtml(event.reason)}</p>` : ""}
              ${event.output?.response ? `<p class="interaction-trace-output">${escapeHtml(event.output.response)}</p>` : ""}
            </div>`)
          .join("");
        return `<section class="test-result-section">
          <div class="interaction-trace-head">
            <h3>Interacciones</h3>
            <span class="interaction-fired-count ${fired.length > 1 ? "is-multi" : ""}">${countLabel}</span>
          </div>
          ${items.length ? `<div class="interaction-trace">${rows}</div>` : '<p class="meta">Sin interacciones.</p>'}
        </section>`;
      }

      testButton?.addEventListener("click", async () => {
        const mensaje = testMessage.value.trim();
        if (!mensaje) return;

        testButton.disabled = true;
        testResult.hidden = false;
        testResult.innerHTML = '<p class="meta">Probando bot...</p>';

        try {
          const response = await fetch(`/inspector/bots/${testPanel.dataset.botId}/test-message`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              organization_id: testPanel.dataset.organizationId,
              account_id: testPanel.dataset.accountId,
              mensaje,
            }),
          });
          const payload = await response.json();

          if (!payload.ok) {
            testResult.innerHTML = `<p class="meta">Error: ${payload.message || payload.error || "No se pudo probar el bot."}</p>`;
            return;
          }

          const result = payload.result;
          const aiNote = result.model_decision
            ? `<p class="meta">Respondió con IA real (${escapeHtml(result.model_decision.provider)} · ${escapeHtml(result.model_decision.model || "modelo no reportado")}).</p>`
            : result.model_error
              ? '<p class="meta">IA real no disponible; se usó el fallback local de prueba.</p>'
              : '<p class="meta">Modo de prueba con IA mock local.</p>';
          const techDetail = result.model_decision
            ? `<p class="meta">Proveedor: ${escapeHtml(result.model_decision.provider)} · Modelo: ${escapeHtml(result.model_decision.model || "—")} · response_id: ${escapeHtml(result.model_decision.response_id || "—")}</p>${result.model_decision.reason ? `<p class="meta">${escapeHtml(result.model_decision.reason)}</p>` : ""}`
            : result.model_error
              ? `<p class="meta">Error IA: ${escapeHtml(result.model_error.code)} — ${escapeHtml(result.model_error.message)}</p>`
              : '<p class="meta">AI: mock local determinístico. Configura AI_PROVIDER=openai para probar con modelo real.</p>';
          testResult.innerHTML = `
            <section class="test-result-section">
              <h3>Respuesta del bot</h3>
              <p>${escapeHtml(result.respuesta)}</p>
              ${aiNote}
            </section>
            ${renderInteractionTrace(result.interaction_trace)}
            <details class="test-tech">
              <summary>Ver detalle técnico</summary>
              <div class="test-tech-body">
                ${techDetail}
                <p class="meta">Prompt compilation: ${escapeHtml(result.prompt_compilation_id)}</p>
                ${renderList("Acciones pedidas", result.action_requests, (action) => `
                  <div class="trace-card">
                    <strong>${escapeHtml(action.action_id)}</strong>
                    <pre>${escapeHtml(JSON.stringify(action.input_json || {}, null, 2))}</pre>
                  </div>
                `)}
                ${renderList("Resultados", result.action_results, (action) => `
                  <div class="trace-card">
                    <strong>${escapeHtml(action.action_id)}</strong>
                    <span class="status">${escapeHtml(action.status)}</span>
                    <pre>${escapeHtml(JSON.stringify(action.output || {}, null, 2))}</pre>
                  </div>
                `)}
                ${renderList("Guardrails", result.guardrail_events_generados, (event) => `
                  <div class="trace-card">
                    <strong>${escapeHtml(event.tipo)}</strong>
                    <p class="meta">${escapeHtml(event.descripcion)}</p>
                  </div>
                `)}
              </div>
            </details>
          `;
        } catch (error) {
          testResult.innerHTML = `<p class="meta">Error: ${error.message}</p>`;
        } finally {
          testButton.disabled = false;
        }
      });
    })();

  script.
    (() => {
      const counters = document.querySelectorAll("textarea[data-char-counter]");
      counters.forEach((textarea) => {
        const target = document.getElementById(textarea.dataset.charCounter);
        if (!target) return;
        const max = textarea.getAttribute("maxlength");
        const update = () => {
          target.textContent = max ? `${textarea.value.length} / ${max}` : String(textarea.value.length);
        };
        textarea.addEventListener("input", update);
        update();
      });
    })();

  script
    include ../../public/js/core/Tab_Navigator.js

  script.
    window.TabNavigator?.render("#bot-editor-tabs");

    // Channels: add/edit via popup (forms post to /inspector/bots/:id/channels and
    // redirect back with ?tab=canales). Deep-link to a tab via ?tab=<section>.
    (() => {
      const botTabs = window.TabNavigator?.get("bot-editor-tabs");
      const requestedTab = new URLSearchParams(window.location.search).get("tab");
      if (botTabs && requestedTab) botTabs.activate_by_section(requestedTab);

      const channelPopup = window.Popup ? new window.Popup({ overlay_selector: "[data-channel-popup]" }) : null;
      channelPopup?.iniciar();
      window.TabNavigator?.render("#channel-popup-tabs");
      const channelTabs = window.TabNavigator?.get("channel-popup-tabs");
      const titleEl = document.querySelector("[data-channel-popup-title]");
      const waDisplay = document.getElementById("channel_wa_display");
      const waMeta = document.getElementById("channel_wa_meta");
      const igUser = document.getElementById("channel_ig_user");
      const igMeta = document.getElementById("channel_ig_meta");

      function openAddChannel() {
        if (titleEl) titleEl.textContent = "Agregar canal";
        if (waDisplay) waDisplay.value = "";
        if (waMeta) { waMeta.value = ""; waMeta.readOnly = false; }
        if (igUser) igUser.value = "";
        if (igMeta) { igMeta.value = ""; igMeta.readOnly = false; }
        channelTabs?.activate_by_section("whatsapp");
        channelPopup?.open();
      }

      function openEditChannel(button) {
        const type = button.dataset.channelType === "instagram" ? "instagram" : "whatsapp";
        if (titleEl) titleEl.textContent = "Editar canal";
        channelTabs?.activate_by_section(type);
        if (type === "instagram") {
          if (igUser) igUser.value = button.dataset.username || "";
          // El ID de Meta identifica el canal: en edición queda readonly para no crear
          // un canal nuevo por upsert. Para reemplazarlo, agrega otro.
          if (igMeta) { igMeta.value = button.dataset.metaId || ""; igMeta.readOnly = true; }
        } else {
          if (waDisplay) waDisplay.value = button.dataset.display || "";
          if (waMeta) { waMeta.value = button.dataset.metaId || ""; waMeta.readOnly = true; }
        }
        channelPopup?.open();
      }

      document.getElementById("open_add_channel")?.addEventListener("click", openAddChannel);
      document.querySelector('.tab-section[data-section="canales"]')?.addEventListener("click", (event) => {
        const editButton = event.target.closest(".channel-edit");
        if (editButton) openEditChannel(editButton);
      });
    })();

  script
