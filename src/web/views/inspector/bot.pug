extends ../layout

block content
  section.page-header
    h1= bot ? bot.name : "Bot no encontrado"
    if bot
      p= `${bot.organization_name} · ${bot.account_name}`

  if bot
    div.two-column
      section.panel
        h2 Configuración base
        dl.compact
          div
            dt Nombre
            dd= bot.name
          div
            dt Propósito
            dd= bot.description || bot.definition_json.description || "sin descripción"
          div
            dt Canal
            dd= bot.channel
          div
            dt Estado
            dd= bot.status
          div
            dt Tipo
            dd= bot.bot_type || "system"

      section.panel
        h2 Canales / accounts asignados
        dl.compact
          div
            dt Account
            dd= bot.account_name
          div
            dt WhatsApp
            dd= bot.display_phone_number || bot.phone_number_id || "sin número"

    section.panel
      h2 Instrucciones base
      if bot.prompt_base || bot.instrucciones_operativas
        if bot.prompt_base
          label Prompt base
          textarea(rows="5", readonly)= bot.prompt_base
        if bot.instrucciones_operativas
          label Instrucciones operativas
          textarea(rows="5", readonly)= bot.instrucciones_operativas
      else if bot.definition_json && (bot.definition_json.goal || bot.definition_json.description)
        if bot.definition_json.goal
          label Objetivo
          textarea(rows="4", readonly)= bot.definition_json.goal
        if bot.definition_json.description
          label Descripción
          textarea(rows="4", readonly)= bot.definition_json.description
      else
        div.empty Sin instrucciones base configuradas.

    section.panel
      h2 Configuración inicial
      textarea(rows="12", readonly)= json(bot.definition_json && Object.keys(bot.definition_json).length ? bot.definition_json : bot.settings_json)

    section.panel
      h2 Conversaciones recientes
      a.button(href=`/inspector/bots/${bot.id}/conversations`) Ver todas
      if conversations.length
        table
          thead
            tr
              th Sender
              th Último mensaje
              th Intent
              th Agent
              th Review
              th Actividad
          tbody
            each conversation in conversations
              tr
                td
                  a(href=`/inspector/conversations/${conversation.id}`)= conversation.display_name || conversation.whatsapp_phone
                  div.meta= conversation.whatsapp_phone
                td= conversation.last_message || "-"
                td= conversation.last_intent || "-"
                td= conversation.last_agent || "-"
                td= conversation.pending_review_count
                td= conversation.last_activity || "-"
      else
        div.empty Sin conversaciones.

    div.two-column
      section.panel
        h2 Agent runs recientes
        if agent_runs.length
          ul.clean-list
            each run in agent_runs
              li
                a(href=run.message_id ? `/inspector/messages/${run.message_id}` : "#")= `${run.agent_key} · ${run.run_type}`
                span.meta= ` · ${run.status}`
        else
          div.empty Sin agent runs.

      section.panel
        h2 Memory docs recientes
        if memory_documents.length
          ul.clean-list
            each document in memory_documents
              li
                a(href=document.message_id ? `/inspector/messages/${document.message_id}` : "#")= document.title || document.document_type
                span.meta= ` · ${document.status} · ${document.embedding_status}`
        else
          div.empty Sin memory docs.
  else
    div.empty No se encontró el bot.
