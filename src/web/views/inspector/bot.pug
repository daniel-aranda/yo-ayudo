extends ../layout

block content
  -
    const definition = bot?.definition_json || {};
    const identity = definition.identity || {};
    const behavior = definition.behavior || {};
    const interactions = Array.isArray(definition.interactions) ? definition.interactions : [];
    const ai = definition.ai || {};
    const ai_model_options = Array.isArray(ai_models) ? ai_models : [];
    const selected_ai_provider = ai.provider || "openai";
    const selected_ai_model = ai.model || (ai_model_options[0] && ai_model_options[0].model) || "gpt-5.5";
    const selected_ai_model_option = ai_model_options.find((option) => option.provider === selected_ai_provider && option.model === selected_ai_model) || ai_model_options[0] || {};
    const selected_ai_model_option_id = selected_ai_model_option.id || `${selected_ai_provider}:${selected_ai_model}`;
    const supported_channel_rows = Array.isArray(supported_channels) ? supported_channels : [];
    const whatsapp_channel_rows = Array.isArray(whatsapp_channels) ? whatsapp_channels : [];
    const primary_whatsapp_channel = whatsapp_channel_rows[0] || {};
    const human_group_options = Array.isArray(human_groups) ? human_groups : [];
    const human_group_options_json = JSON.stringify(human_group_options).replace(/</g, "\\u003c");
    const assigned_knowledge_sources = Array.isArray(knowledge_sources) ? knowledge_sources : [];
    const all_knowledge_sources = Array.isArray(available_knowledge_sources) ? available_knowledge_sources : [];
    const knowledge_ids = Array.isArray(definition.knowledge_source_ids) ? definition.knowledge_source_ids : [];
    const assigned_knowledge_ids = new Set(assigned_knowledge_sources.map((source) => source.id).concat(knowledge_ids));
    const addable_knowledge_sources = all_knowledge_sources.filter((source) => !assigned_knowledge_ids.has(source.id));
    const system_interactions = Array.isArray(available_interactions) ? available_interactions : [];
    const configured_types = new Set(interactions.map((interaction) => interaction.type));
    const addable_interactions = system_interactions.filter((interaction) => !configured_types.has(interaction.type));
    const settings_json = Object.keys(definition).length ? definition : (bot?.settings_json || {});
    const bot_name = identity.name || bot?.name || "Agente no encontrado";
    const bot_description = identity.description || bot?.description || "";
    const bot_goal = identity.goal || definition.goal || "";
    const behavior_language = behavior.language || "es-MX";
    const behavior_tone = behavior.tone || bot?.tono || "professional";
    const operating_instructions = behavior.operating_instructions || bot?.instrucciones_operativas || "";
    const constraints_text = Array.isArray(behavior.constraints) ? behavior.constraints.join("\n") : (behavior.constraints || "");
    const knowledge_type_label = (type) => {
      if (type === "document") return "Documento";
      if (type === "url") return "URL";
      return "Texto";
    };
    const knowledge_preview = (value) => {
      const text = String(value || "").trim();
      if (!text) return "";
      return text.length > 220 ? `${text.slice(0, 220)}...` : text;
    };
    const last_saved_at_iso = bot?.updated_at ? new Date(bot.updated_at).toISOString() : "";
    const svg_open = '<svg class="ui-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">';
    const editor_icons = {
      user: `${svg_open}<circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.6 3.2-5.5 7-5.5s7 1.9 7 5.5"/></svg>`,
      chat: `${svg_open}<path d="M6 5h12a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3.5V7a2 2 0 0 1 2-2z"/></svg>`,
      play: `${svg_open}<circle cx="12" cy="12" r="9"/><path d="M10 8.5l5.5 3.5L10 15.5z" fill="currentColor" stroke="none"/></svg>`,
      book: `${svg_open}<path d="M4 5.5A1.5 1.5 0 0 1 5.5 4H11v15.5H5.5A1.5 1.5 0 0 0 4 21z"/><path d="M20 5.5A1.5 1.5 0 0 0 18.5 4H13v15.5h5.5A1.5 1.5 0 0 1 20 21z"/></svg>`,
      broadcast: `${svg_open}<circle cx="12" cy="12" r="1.8"/><path d="M8.6 8.6a5 5 0 0 0 0 6.8M15.4 8.6a5 5 0 0 1 0 6.8M6.2 6.2a9 9 0 0 0 0 11.6M17.8 6.2a9 9 0 0 1 0 11.6"/></svg>`,
      bolt: `${svg_open}<path d="M13 3L5.5 13H11l-1 8 8.5-11.5H13z"/></svg>`,
      lock: `${svg_open}<rect x="5" y="10.5" width="14" height="9.5" rx="2"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/></svg>`,
      gear: `${svg_open}<circle cx="12" cy="12" r="3"/><path d="M12 2.5v3M12 18.5v3M2.5 12h3M18.5 12h3M5.2 5.2l2.1 2.1M16.7 16.7l2.1 2.1M18.8 5.2l-2.1 2.1M7.3 16.7l-2.1 2.1"/></svg>`,
      globe: `${svg_open}<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.6 2.6 2.6 15.4 0 18M12 3c-2.6 2.6-2.6 15.4 0 18"/></svg>`,
      smiley: `${svg_open}<circle cx="12" cy="12" r="9"/><path d="M8.5 14c.8 1.2 2 1.9 3.5 1.9s2.7-.7 3.5-1.9"/><path d="M9 9.5h.01M15 9.5h.01"/></svg>`,
      sparkles: `${svg_open}<path d="M12 3l1.7 4.3L18 9l-4.3 1.7L12 15l-1.7-4.3L6 9l4.3-1.7z"/><path d="M18.5 14l.7 1.8 1.8.7-1.8.7-.7 1.8-.7-1.8-1.8-.7 1.8-.7z"/></svg>`,
      id_card: `${svg_open}<rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="11" r="2"/><path d="M13 9.5h5M13 13h5M5.5 16c0-1.3 1.3-2 3-2s3 .7 3 2"/></svg>`,
    };
    const editor_icon = (name) => editor_icons[name] || `${svg_open}<circle cx="12" cy="12" r="9"/></svg>`;

  mixin icon(name)
    != editor_icon(name)

  mixin section_head(icon_name, title, subtitle)
    div.section-head
      span.section-badge!= editor_icon(icon_name)
      div
        h2= title
        if subtitle
          p.section-sub= subtitle

  if bot
    section.page-header.builder-header
      div
        h1= bot_name
        p= `${bot.organization_name || "Organization"} / ${bot.account_name || "Account"}`
      div.builder-actions
        div#autosave-indicator.autosave-indicator.idle(aria-live="polite", data-saved-at=last_saved_at_iso)
          span.autosave-dot(aria-hidden="true")
          span.autosave-text
          button.autosave-retry(type="button", hidden) Reintentar
        details.json-toggle
          summary Ver settings JSON
          pre= JSON.stringify(settings_json, null, 2)

    form(method="post", action=`/inspector/bots/${bot.id}`, id="bot-editor")
      div.bot-editor-tab-shell.wamy-tabs
        div#bot-editor-tabs.tabs(data-initial-tab="identidad", role="tablist", aria-label="Editor de bot")
          button.tab.active(type="button", data-section="identidad", role="tab", aria-selected="true")
            +icon("user")
            span Identidad
          button.tab(type="button", data-section="conversaciones", role="tab", aria-selected="false")
            +icon("chat")
            span Conversaciones
          button.tab(type="button", data-section="probar", role="tab", aria-selected="false")
            +icon("play")
            span Probar
          button.tab(type="button", data-section="knowledge", role="tab", aria-selected="false")
            +icon("book")
            span Knowledge
          button.tab(type="button", data-section="canales", role="tab", aria-selected="false")
            +icon("broadcast")
            span Canales
          button.tab(type="button", data-section="interacciones", role="tab", aria-selected="false")
            +icon("bolt")
            span Interacciones
          button.tab(type="button", data-section="restricciones", role="tab", aria-selected="false")
            +icon("lock")
            span Restricciones

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="identidad")
        +section_head("user", "Identidad del agente", "Define los datos principales y el propósito de este agente.")
        div.form-grid
          div
            label(for="name") Nombre
            div.field-control.has-trailing
              input#name(type="text", name="name", value=bot_name)
              span.field-trailing-icon(aria-hidden="true")!= editor_icon("id_card")
          div
            label(for="status") Estado
            div.field-control.has-leading
              span.status-dot(class=`is-${bot.status || identity.status || "draft"}`, aria-hidden="true")
              select#status(name="status")
                each status_option in ["draft", "active", "archived"]
                  option(value=status_option, selected=(bot.status || identity.status) === status_option)= status_option
          div
            label(for="bot_type") Tipo
            select#bot_type(name="bot_type")
              each type_option in ["system", "custom"]
                option(value=type_option, selected=(bot.bot_type || identity.type) === type_option)= type_option
        div.form-grid
          div
            label(for="description") Descripción
            textarea#description(name="description", rows="3")= bot_description
          div
            label(for="goal") Objetivo
            textarea#goal(name="goal", rows="3")= bot_goal

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="identidad")
        +section_head("gear", "Instrucciones operativas", "Configura el idioma, tono, modelo y las instrucciones para este agente.")
        div.form-grid
          div
            label(for="behavior_language") Idioma
            div.field-control.has-leading
              span.field-lead-icon(aria-hidden="true")!= editor_icon("globe")
              select#behavior_language(name="behavior_language")
                option(value="es-MX", selected=behavior_language === "es-MX") Español México
                option(value="en-US", selected=behavior_language === "en-US") English US
          div
            label(for="behavior_tone") Tono
            div.field-control.has-leading
              span.field-lead-icon(aria-hidden="true")!= editor_icon("smiley")
              select#behavior_tone(name="behavior_tone")
                option(value="direct", selected=behavior_tone === "direct") Directo
                option(value="friendly", selected=behavior_tone === "friendly") Amable
                option(value="professional", selected=behavior_tone === "professional") Profesional
                option(value="commercial", selected=behavior_tone === "commercial") Comercial
                option(value="technical", selected=behavior_tone === "technical") Técnico
                option(value="casual", selected=behavior_tone === "casual") Casual
          div
            label(for="ai_model_selection") Modelo IA
            div.field-control.has-leading
              span.field-lead-icon(aria-hidden="true")!= editor_icon("sparkles")
              select#ai_model_selection(name="ai_model_selection")
                each model_option in ai_model_options
                  option(value=model_option.id, selected=selected_ai_model_option_id === model_option.id)= model_option.label
        div.field-with-counter
          label(for="instrucciones_operativas") Instrucciones
          textarea#instrucciones_operativas(
            name="instrucciones_operativas",
            rows="8",
            maxlength="2000",
            data-char-counter="instrucciones_counter",
            placeholder="Describe cómo debe operar este agente, qué debe priorizar, cuándo debe preguntar, cómo debe usar knowledge y cuándo debe consultar humanos."
          )= operating_instructions
          span#instrucciones_counter.char-counter(aria-hidden="true")

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="knowledge", hidden)
        div.section-title
          +section_head("book", "Knowledge", "Fuentes de conocimiento que el agente puede usar para responder.")
          a.button(href=`/inspector/knowledge?organization_id=${bot.organization_id}&account_id=${bot.account_id}`) Ir a Knowledge Center
        div.inline-add-row
          if addable_knowledge_sources.length
            select#knowledge_source_picker
              option(value="") Selecciona knowledge existente
              each source in addable_knowledge_sources
                option(value=source.id, data-name=source.name, data-type=source.source_type, data-status=source.status, data-summary=source.summary || "")= source.name
            button#add_knowledge_source(type="button") Asignar knowledge
          else
            select(disabled)
              option Todo el knowledge disponible ya está asignado
            button(type="button", disabled) Asignar knowledge
        if assigned_knowledge_sources.length
          div.table-wrap#assigned_knowledge_table
            table
              thead
                tr
                  th Fuente
                  th Tipo
                  th Estado
                  th Knowledge
              tbody
                each source in assigned_knowledge_sources
                  tr
                    td
                      strong= source.name
                      if source.description
                        p.meta= source.description
                      input(type="hidden", name="knowledge_source_ids", value=source.id)
                    td= knowledge_type_label(source.source_type)
                    td
                      span.status= source.status
                    td
                      if source.summary_status
                        span.status= source.summary_status
                      if source.summary
                        p.meta= knowledge_preview(source.summary)
        else
          div.empty#knowledge_empty_state Este agente todavía no tiene knowledge asignado. Selecciona una fuente existente o créala en Knowledge Center.
          div#assigned_knowledge_hidden
            each knowledge_id in knowledge_ids
              input(type="hidden", name="knowledge_source_ids", value=knowledge_id)

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="canales", hidden)
        +section_head("broadcast", "Canales soportados", "Conecta el número de WhatsApp por donde te escriben tus clientes.")
        if supported_channel_rows.length
          each channel in supported_channel_rows
            if channel.channel === "whatsapp"
              div.channel-config
                div.channel-header
                  div.channel-title
                    span.channel-icon(aria-hidden="true") WA
                    div
                      h3= channel.label
                      p.meta El número por donde tus clientes le escriben a este agente.
                  if whatsapp_channel_rows.length
                    span.channel-status.is-connected Conectado
                  else
                    span.channel-status.is-idle Sin conectar
                div.form-grid
                  div
                    label(for="whatsapp_display_phone_number") Número de WhatsApp
                    input#whatsapp_display_phone_number(
                      type="tel",
                      name="whatsapp_display_phone_number",
                      value=primary_whatsapp_channel.display_phone_number || "",
                      placeholder="+52 55 1234 5678"
                    )
                    p.field-hint El número con lada que ven tus clientes.
                  div
                    label(for="whatsapp_phone_number_id") ID del número en Meta
                    input#whatsapp_phone_number_id(
                      type="text",
                      name="whatsapp_phone_number_id",
                      value=primary_whatsapp_channel.phone_number_id || "",
                      placeholder="1234567890"
                    )
                    p.field-hint En Meta WhatsApp Manager → Configuración de la API (phone_number_id).
                if whatsapp_channel_rows.length
                  div.table-wrap
                    table
                      thead
                        tr
                          th Número
                          th ID Meta
                          th Estado
                      tbody
                        each whatsapp_channel in whatsapp_channel_rows
                          tr
                            td= whatsapp_channel.display_phone_number || "Sin número"
                            td= whatsapp_channel.phone_number_id
                            td
                              span.status= whatsapp_channel.status
                else
                  p.channel-hint Llena ambos campos para conectar el número. Los cambios se guardan automáticamente.
        else
          div.empty Ningún canal soportado disponible.

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="interacciones", hidden)
        +section_head("bolt", "Interacciones", "Lo que el agente puede hacer y cómo. Cada interacción tiene su propio prompt que define cuándo y cómo usarla.")
        if interactions.length
          div.interaction-grid
            each interaction, index in interactions
              -
                const system_interaction = system_interactions.find((item) => item.type === interaction.type) || interaction;
              div.interaction-card
                input(type="hidden", name="interaction_type", value=system_interaction.type)
                div.section-title
                  div
                    h3= system_interaction.label || interaction.label
                    if system_interaction.description
                      p.meta= system_interaction.description
                  label.checkbox-line
                    input(type="checkbox", name="interaction_enabled", value=index, checked=interaction.enabled !== false)
                    | Habilitada
                label Instrucciones
                textarea(
                  name="interaction_instructions",
                  rows="4",
                  placeholder=system_interaction.instructions_placeholder || "Describe cuándo y cómo debe usar esta interacción."
                )= interaction.instructions || ""
                if interaction.type === "consult_human"
                  -
                    const selected_human_group_id = Array.isArray(interaction.human_group_ids)
                      ? interaction.human_group_ids.find((id) => human_group_options.some((group) => group.id === id)) || ""
                      : "";
                  label(for=`interaction_human_group_ids_${index}`) Grupos humanos
                  select(
                    id=`interaction_human_group_ids_${index}`,
                    name="interaction_human_group_ids",
                  )
                    option(value="") Selecciona grupo humano
                    each group in human_group_options
                      option(value=group.id, selected=selected_human_group_id === group.id)= group.label
                  if !selected_human_group_id
                    p.config-warning Sin grupo humano asignado: el agente no sabrá a quién escalar.
                else
                  input(type="hidden", name="interaction_human_group_ids", value="")
        else
          div.empty#interaction_empty_state Ninguna interacción configurada.

        div.inline-add-row
          if addable_interactions.length
            select#interaction_picker
              option(value="") Selecciona una interacción
              each interaction in addable_interactions
                option(
                  value=interaction.type,
                  data-key=interaction.key,
                  data-label=interaction.label,
                  data-description=interaction.description,
                  data-placeholder=interaction.instructions_placeholder
                )= interaction.label
            button#add_interaction(type="button") Agregar interacción
          else
            select(disabled)
              option Tienes todas las interacciones conectadas
            button(type="button", disabled) Agregar interacción

        if addable_interactions.length
          div#new_interaction_mount
        else
          p.meta Todas las interacciones disponibles ya están configuradas.

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="restricciones", hidden)
        +section_head("lock", "Restricciones", "Qué no debe prometer el agente, cuándo detenerse y cuándo escalar a un humano.")
        div.field-with-counter
          textarea(
            name="constraints_text",
            rows="6",
            maxlength="2000",
            data-char-counter="constraints_counter",
            placeholder="Describe las restricciones del agente: qué no debe prometer, cuándo debe detenerse y cuándo debe consultar a un humano."
          )= constraints_text
          span#constraints_counter.char-counter(aria-hidden="true")

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="probar", hidden)
        +section_head("play", "Probar bot", "Envía un mensaje de prueba y mira cómo responde el agente.")
        div.test-bot-panel(
          data-autosave-ignore,
          data-bot-id=bot.id,
          data-organization-id=bot.organization_id || "",
          data-account-id=bot.account_id || ""
        )
          label(for="test_bot_message") Mensaje de prueba
          textarea#test_bot_message(
            rows="5",
            placeholder="Escribe un mensaje como si llegara por WhatsApp. Ej. Consulta a humano si podemos prometer llamadas automáticas y crea una tarea de seguimiento."
          )
          button#run_bot_test(type="button") Probar bot
          div#bot_test_result.test-result(hidden)

      section.panel.tab-section(data-parent-tab="bot-editor-tabs", data-section="conversaciones", hidden)
        +section_head("chat", "Conversaciones recientes", "Las conversaciones más recientes de este agente.")
        if conversations.length
          ul.clean-list
            each conversation in conversations
              li
                a(href=`/inspector/conversations/${conversation.id}`)= conversation.contact_display_name || conversation.contact_phone || conversation.id
                span.meta= ` · ${conversation.status || "active"}`
        else
          div.empty Sin conversaciones recientes.
  else
    section.page-header
      h1 Agente no encontrado
      p No se encontró el bot solicitado.

  script.
    (() => {
      const interactionPicker = document.getElementById("interaction_picker");
      const addInteractionButton = document.getElementById("add_interaction");
      const interactionMount = document.getElementById("new_interaction_mount");
      const interactionGrid = document.querySelector(".interaction-grid");
      const interactionEmptyState = document.getElementById("interaction_empty_state");
      const humanGroupOptions = !{human_group_options_json};

      function renderHumanGroupSelect() {
        const options = humanGroupOptions
          .map((group) => `<option value="${escapeHtml(group.id)}">${escapeHtml(group.label)}</option>`)
          .join("");
        return `<label>Grupos humanos</label><select name="interaction_human_group_ids"><option value="">Selecciona grupo humano</option>${options}</select>`;
      }

      function syncInteractionPicker() {
        if (!interactionPicker || !addInteractionButton) return;
        const hasOptions = Array.from(interactionPicker.options).some((option) => option.value);
        interactionPicker.disabled = !hasOptions;
        addInteractionButton.disabled = !hasOptions;
        if (!hasOptions) {
          interactionPicker.innerHTML = '<option>Tienes todas las interacciones conectadas</option>';
        }
      }

      addInteractionButton?.addEventListener("click", () => {
        const option = interactionPicker.selectedOptions[0];
        if (!option?.value || !interactionMount) return;
        const index = document.querySelectorAll('input[name="interaction_type"]').length;
        const type = option.value;
        const label = option.dataset.label || option.textContent;
        const description = option.dataset.description || "";
        const placeholder = option.dataset.placeholder || "Describe cuándo y cómo debe usar esta interacción.";
        const humanField =
          type === "consult_human"
            ? renderHumanGroupSelect()
            : '<input type="hidden" name="interaction_human_group_ids" value="">';
        const card = document.createElement("div");
        card.className = "interaction-card";
        card.innerHTML = `
          <input type="hidden" name="interaction_type" value="${type}">
          <div class="section-title">
            <div>
              <h3>${label}</h3>
              ${description ? `<p class="meta">${description}</p>` : ""}
            </div>
            <label class="checkbox-line">
              <input type="checkbox" name="interaction_enabled" value="${index}" checked>
              Habilitada
            </label>
          </div>
          <label>Instrucciones</label>
          <textarea name="interaction_instructions" rows="4" placeholder="${placeholder}"></textarea>
          ${humanField}
        `;
        if (interactionGrid) {
          interactionGrid.appendChild(card);
        } else {
          const grid = document.createElement("div");
          grid.className = "interaction-grid";
          grid.appendChild(card);
          interactionMount.before(grid);
        }
        interactionEmptyState?.remove();
        option.remove();
        interactionPicker.value = "";
        syncInteractionPicker();
        window.bot_editor_autosave?.request_save({
          control: { name: "interaction_type", tag: "button", value: type },
          event: { type: "add_interaction" },
        });
      });

      syncInteractionPicker();

      const knowledgePicker = document.getElementById("knowledge_source_picker");
      const addKnowledgeButton = document.getElementById("add_knowledge_source");
      const knowledgeHiddenMount = document.getElementById("assigned_knowledge_hidden");
      const knowledgeEmptyState = document.getElementById("knowledge_empty_state");

      function syncKnowledgePicker() {
        if (!knowledgePicker || !addKnowledgeButton) return;
        const hasOptions = Array.from(knowledgePicker.options).some((option) => option.value);
        knowledgePicker.disabled = !hasOptions;
        addKnowledgeButton.disabled = !hasOptions;
        if (!hasOptions) {
          knowledgePicker.innerHTML = "<option>Todo el knowledge disponible ya está asignado</option>";
        }
      }

      addKnowledgeButton?.addEventListener("click", () => {
        const option = knowledgePicker.selectedOptions[0];
        if (!option?.value) return;
        const hidden = document.createElement("input");
        hidden.type = "hidden";
        hidden.name = "knowledge_source_ids";
        hidden.value = option.value;
        (knowledgeHiddenMount || document.getElementById("bot-editor")).appendChild(hidden);
        knowledgeEmptyState?.remove();
        option.remove();
        knowledgePicker.value = "";
        syncKnowledgePicker();
        window.bot_editor_autosave?.request_save({
          control: { name: "knowledge_source_ids", tag: "button", value: hidden.value },
          event: { type: "add_knowledge_source" },
        });
      });

      syncKnowledgePicker();

      const testPanel = document.querySelector(".test-bot-panel");
      const testButton = document.getElementById("run_bot_test");
      const testMessage = document.getElementById("test_bot_message");
      const testResult = document.getElementById("bot_test_result");

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function renderList(title, items, mapper) {
        const rows = (items || []).map(mapper).join("");
        return `<section class="test-result-section"><h3>${title}</h3>${rows || '<p class="meta">Sin registros.</p>'}</section>`;
      }

      testButton?.addEventListener("click", async () => {
        const mensaje = testMessage.value.trim();
        if (!mensaje) return;

        testButton.disabled = true;
        testResult.hidden = false;
        testResult.innerHTML = '<p class="meta">Probando bot...</p>';

        try {
          const response = await fetch(`/inspector/bots/${testPanel.dataset.botId}/test-message`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              organization_id: testPanel.dataset.organizationId,
              account_id: testPanel.dataset.accountId,
              mensaje,
            }),
          });
          const payload = await response.json();

          if (!payload.ok) {
            testResult.innerHTML = `<p class="meta">Error: ${payload.message || payload.error || "No se pudo probar el bot."}</p>`;
            return;
          }

          const result = payload.result;
          const modelDecision = result.model_decision
            ? `<p class="meta">AI real: ${escapeHtml(result.model_decision.provider)} · ${escapeHtml(result.model_decision.model || "modelo no reportado")} · ${escapeHtml(result.model_decision.response_id || "sin response_id")}</p><p class="meta">${escapeHtml(result.model_decision.reason || "")}</p>`
            : result.model_error
              ? `<p class="meta">AI real no disponible (${escapeHtml(result.model_error.code)}). Fallback local usado: ${escapeHtml(result.model_error.message)}</p>`
              : '<p class="meta">AI: mock local determinístico. Configura AI_PROVIDER=openai para probar con modelo real.</p>';
          testResult.innerHTML = `
            <section class="test-result-section">
              <h3>Respuesta del bot</h3>
              <p>${escapeHtml(result.respuesta)}</p>
              ${modelDecision}
              <p class="meta">Prompt compilation: ${escapeHtml(result.prompt_compilation_id)}</p>
            </section>
            ${renderList("Interacciones", result.interaction_trace, (event) => `
              <div class="trace-card">
                <strong>${escapeHtml(event.label || event.interaction_type)}</strong>
                <span class="status">${escapeHtml(event.status)}</span>
                <p class="meta">${escapeHtml(event.reason || "")}</p>
                ${event.output?.response ? `<p>${escapeHtml(event.output.response)}</p>` : ""}
              </div>
            `)}
            ${renderList("Acciones pedidas", result.action_requests, (action) => `
              <div class="trace-card">
                <strong>${escapeHtml(action.action_id)}</strong>
                <pre>${escapeHtml(JSON.stringify(action.input_json || {}, null, 2))}</pre>
              </div>
            `)}
            ${renderList("Resultados", result.action_results, (action) => `
              <div class="trace-card">
                <strong>${escapeHtml(action.action_id)}</strong>
                <span class="status">${escapeHtml(action.status)}</span>
                <pre>${escapeHtml(JSON.stringify(action.output || {}, null, 2))}</pre>
              </div>
            `)}
            ${renderList("Guardrails", result.guardrail_events_generados, (event) => `
              <div class="trace-card">
                <strong>${escapeHtml(event.tipo)}</strong>
                <p class="meta">${escapeHtml(event.descripcion)}</p>
              </div>
            `)}
          `;
        } catch (error) {
          testResult.innerHTML = `<p class="meta">Error: ${error.message}</p>`;
        } finally {
          testButton.disabled = false;
        }
      });
    })();

  script.
    (() => {
      const counters = document.querySelectorAll("textarea[data-char-counter]");
      counters.forEach((textarea) => {
        const target = document.getElementById(textarea.dataset.charCounter);
        if (!target) return;
        const max = textarea.getAttribute("maxlength");
        const update = () => {
          target.textContent = max ? `${textarea.value.length} / ${max}` : String(textarea.value.length);
        };
        textarea.addEventListener("input", update);
        update();
      });
    })();

  script
